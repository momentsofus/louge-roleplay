# ─── 本地开发（最小配置）─────────────────────────────────────────────────────────
# 不设置 DATABASE_URL → 自动使用本地 SQLite（data/local.db），无需安装 MySQL
# 不设置 REDIS_URL   → 自动使用内存模式，无需安装 Redis
#
# 最简启动只需以下三行：
PORT=3217
APP_NAME=楼阁
SESSION_SECRET=dev_secret_change_in_prod
#
# AI 对话需要配置（否则对话功能不可用）：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ─── 生产环境（完整配置）─────────────────────────────────────────────────────────
# PORT=3217
# APP_NAME=楼阁
# APP_URL=https://example.com
# SESSION_SECRET=please_replace_with_random_64_chars

# 数据库（不配置则降级到 SQLite）
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/dbname
# DATABASE_ADMIN_URL=mysql://root:password@127.0.0.1:3306

# Redis（不配置则使用内存 session，重启后登录状态丢失）
# REDIS_URL=redis://:password@127.0.0.1:6379

# AI Provider
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Email verification via Resend
# RESEND_API_KEY=
# RESEND_FROM=Name <noreply@example.com>

# Aliyun phone auth
# ALIYUN_PHONE_AUTH_ENABLED=false
# ALIYUN_PHONE_AUTH_APP_ID=
# ALIYUN_PHONE_AUTH_APP_KEY=
# ALIYUN_PHONE_AUTH_EXPOSE_APP_KEY=false

# TRUST_PROXY=true
# COOKIE_SECURE=true
# PRODUCTION_FAIL_FAST=true
# ALLOW_PRODUCTION_SQLITE_FALLBACK=false
# ALLOW_PRODUCTION_MEMORY_REDIS=false
# RATE_LIMIT_FAIL_CLOSED=true
#
# 生产发布前建议运行：
# npm run security:audit && npm run health:check
