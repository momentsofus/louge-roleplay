<!-- @file src/views/home.ejs
     @description 首页模板。调用说明：GET / 渲染，展示轻量推荐角色并引导进入公开角色页。
-->
<div class="home-shell">
  <section class="hero-card home-hero-card">
    <div>
      <div class="section-kicker">Louge</div>
      <h1>创建可控的 AI 角色，并持续管理每一段对话。</h1>
      <p>楼阁用于创建、导入和管理 AI 角色。你可以维护角色设定、公开分享角色，并在独立会话中持续对话。</p>
      <div class="home-hero-actions">
        <a class="quick-link" href="/characters/public">浏览公开角色</a>
        <% if (currentUser) { %>
          <a class="quick-link" href="/characters/new">创建新角色</a>
        <% } else { %>
          <a class="quick-link" href="/register">注册账号</a>
        <% } %>
      </div>
    </div>
    <div class="hero-meta">
      <div class="hero-stat">
        <strong>公开角色热度</strong>
        <span>公开角色支持点赞、评论、使用量和综合热度排序，首页只保留轻量推荐。</span>
      </div>
      <div class="hero-stat">
        <strong>多用户空间</strong>
        <span>每个账号都拥有独立的角色、会话、资料和可用额度。</span>
      </div>
      <div class="hero-stat">
        <strong>入口</strong>
        <span>aicafe.momentsofus.cn</span>
      </div>
    </div>
  </section>

  <section class="home-featured-section">
    <div class="section-head">
      <div>
        <h2>最近公开的角色</h2>
        <p>首页展示部分公开角色。进入公开角色页后，可以按热度、点赞、评论、使用量和标签进一步筛选。</p>
      </div>
      <a class="quick-link" href="/characters/public">查看全部</a>
    </div>

    <% if (characters.length === 0) { %>
      <div class="empty-card home-empty">还没有公开角色。注册账号后可以创建并发布第一个角色。</div>
    <% } %>

    <% if (characters.length > 0) { %>
      <div class="character-grid character-grid--featured">
        <% characters.forEach(character => { %>
          <article class="character-card">
            <% if (character.avatar_image_path) { %>
              <div class="character-avatar character-avatar--image"><img src="<%= character.avatar_image_path %>" alt="<%= character.name %>" loading="lazy" decoding="async" /></div>
            <% } %>
            <h3><a href="/characters/public/<%= character.id %>"><%= character.name %></a></h3>
            <p class="character-summary character-summary--clamped"><%= character.summary || '这个角色还没有写简介。' %></p>
            <div class="character-card-stats">
              <span><%= character.heat_score || 0 %> 热度</span>
              <span><%= character.like_count || 0 %> 赞</span>
              <span><%= character.comment_count || 0 %> 评论</span>
            </div>
            <a class="quick-link" href="/characters/public/<%= character.id %>">查看详情</a>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>
