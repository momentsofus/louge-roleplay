<!-- @file src/views/admin-conversations.ejs
     @description 管理后台全局对话记录列表。调用说明：GET /admin/conversations 渲染，支持按用户、角色卡、日期筛选和分页查看。
-->
<div class="admin-shell">
  <section class="hero-card admin-hero">
    <div class="admin-hero-copy">
      <p class="section-kicker">Conversations</p>
      <h1><%= t('全局对话记录') %></h1>
      <p class="muted-text"><%= t('全站会话集中在这里看。按用户、角色卡、日期筛一下，再点详情看完整消息链，别再翻数据库了。') %></p>
    </div>

    <div class="metrics metrics--compact">
      <div class="metric"><strong><%= conversationResult.total %></strong><span><%= t('匹配会话') %></span></div>
      <div class="metric"><strong><%= conversationResult.page %> / <%= conversationResult.totalPages %></strong><span><%= t('当前页') %></span></div>
      <div class="metric"><strong><%= conversationResult.conversations.reduce((sum, item) => sum + Number(item.message_count || 0), 0) %></strong><span><%= t('本页消息数') %></span></div>
    </div>
  </section>

  <section class="section-card admin-section">
    <div class="admin-subnav">
      <a class="quick-link" href="/admin">用户与总览</a>
      <a class="quick-link" href="/admin/providers">LLM 配置</a>
      <a class="quick-link" href="/admin/plans">套餐配置</a>
      <a class="quick-link" href="/admin/prompts">Prompt 配置</a>
      <a class="quick-link" href="/admin/logs"><%= t('日志查询') %></a>
      <a class="quick-link is-active" href="/admin/conversations"><%= t('对话记录') %></a>
    </div>

    <div class="section-heading">
      <div>
        <p class="section-kicker">Filters</p>
        <h2><%= t('筛选条件') %></h2>
        <p class="muted-text"><%= t('角色卡、日期、用户都能筛。留空就是看全局。') %></p>
      </div>
    </div>

    <form class="admin-log-filter" method="get" action="/admin/conversations">
      <label>
        <%= t('用户') %>
        <select name="userId">
          <option value=""><%= t('全部用户') %></option>
          <% conversationResult.filterOptions.users.forEach(user => { %>
            <option value="<%= user.id %>" <%= Number(conversationResult.filters.userId) === Number(user.id) ? 'selected' : '' %>>
              <%= user.label %>（<%= user.count %>）
            </option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t('角色卡') %>
        <select name="characterId">
          <option value=""><%= t('全部角色卡') %></option>
          <% conversationResult.filterOptions.characters.forEach(character => { %>
            <option value="<%= character.id %>" <%= Number(conversationResult.filters.characterId) === Number(character.id) ? 'selected' : '' %>>
              <%= character.label %>（<%= character.count %>）
            </option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t('日期') %>
        <input type="date" name="date" value="<%= conversationResult.filters.date %>" />
      </label>
      <label>
        <%= t('每页') %>
        <select name="pageSize">
          <% [10, 25, 50, 100].forEach(size => { %>
            <option value="<%= size %>" <%= Number(conversationResult.pageSize) === size ? 'selected' : '' %>><%= size %></option>
          <% }) %>
        </select>
      </label>
      <div class="toolbar-row toolbar-row--admin admin-log-filter-actions">
        <button type="submit"><%= t('查询对话') %></button>
        <a class="quick-link" href="/admin/conversations"><%= t('清空筛选') %></a>
      </div>
    </form>
  </section>

  <section class="section-card admin-section">
    <div class="toolbar-row toolbar-row--between">
      <div>
        <p class="section-kicker">Result</p>
        <h2><%= t('会话列表') %></h2>
      </div>
      <div class="admin-pagination">
        <% if (conversationResult.page > 1) { %>
          <a class="quick-link" href="<%= buildPageUrl(conversationResult.page - 1) %>"><%= t('上一页') %></a>
        <% } %>
        <span class="meta-chip"><strong><%= conversationResult.page %></strong> / <%= conversationResult.totalPages %></span>
        <% if (conversationResult.page < conversationResult.totalPages) { %>
          <a class="quick-link" href="<%= buildPageUrl(conversationResult.page + 1) %>"><%= t('下一页') %></a>
        <% } %>
      </div>
    </div>

    <% if (!conversationResult.conversations.length) { %>
      <div class="empty-state">
        <strong><%= t('没查到对话') %></strong>
        <span class="muted-text"><%= t('换个用户、角色卡或日期试试。') %></span>
      </div>
    <% } %>

    <div class="admin-log-list">
      <% conversationResult.conversations.forEach(conversation => { %>
        <article class="admin-item admin-conversation-card">
          <div class="admin-conversation-summary">
            <div class="admin-item-main">
              <span class="pill pill--brand">#<%= conversation.id %></span>
              <strong><%= conversation.title || t('未命名对话') %></strong>
              <span class="pill"><%= conversation.status %></span>
              <span class="pill"><%= conversation.selected_model_mode || 'standard' %></span>
            </div>
            <div class="admin-item-meta">
              <span class="meta-chip"><%= t('消息 {count}', { count: conversation.message_count }) %></span>
              <span class="meta-chip"><%= t('更新 {updatedAt}', { updatedAt: conversation.display_updated_at }) %></span>
              <a class="quick-link" href="/admin/conversations/<%= conversation.id %>"><%= t('查看详情') %></a>
            </div>
          </div>
          <div class="admin-log-meta-grid">
            <span><strong><%= t('用户') %></strong><%= conversation.nickname ? `${conversation.username}（${conversation.nickname}）` : conversation.username %></span>
            <span><strong><%= t('角色卡') %></strong><%= conversation.character_name %></span>
            <span><strong><%= t('创建时间') %></strong><%= conversation.display_created_at %></span>
            <span><strong><%= t('最后消息') %></strong><%= conversation.display_last_message_at %></span>
          </div>
          <p class="admin-conversation-preview">
            <span><%= conversation.latest_sender_type || '—' %></span>
            <%= conversation.latest_message_preview || t('暂无消息内容') %>
          </p>
        </article>
      <% }) %>
    </div>
  </section>
</div>
