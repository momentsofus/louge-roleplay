<style>
  .register-shell {
    display: grid;
    grid-template-columns: 1.05fr 1.2fr;
    gap: 24px;
    align-items: stretch;
    animation: fadeIn var(--duration-slow) var(--ease-out) both;
  }

  .register-hero {
    background: linear-gradient(135deg, #12101f 0%, #1a1530 50%, #0f1628 100%);
    color: var(--text);
    border: 1px solid rgba(124, 92, 252, 0.12);
    border-radius: var(--radius-2xl);
    padding: 36px;
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 680px;
    position: relative;
    overflow: hidden;
  }

  .register-hero::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(124, 92, 252, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .register-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: var(--radius-full);
    background: rgba(124, 92, 252, 0.12);
    color: var(--brand-hover);
    font-size: 12px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    margin-bottom: 18px;
    font-weight: 500;
  }

  .register-hero h1 {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.1;
    margin-bottom: 16px;
    color: #fff;
  }

  .register-hero p {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .register-hero-list {
    display: grid;
    gap: 12px;
    margin-top: 24px;
  }

  .register-hero-item {
    padding: 16px 18px;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(8px);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .register-hero-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(124, 92, 252, 0.2);
  }

  .register-hero-item strong {
    display: block;
    font-size: 15px;
    color: var(--text);
    margin-bottom: 6px;
  }

  .register-hero-item span {
    color: var(--text-tertiary);
    font-size: 14px;
    line-height: 1.6;
  }

  .register-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    padding: 32px;
    box-shadow: var(--shadow-md);
  }

  .register-panel-header {
    margin-bottom: 24px;
  }

  .register-panel-header h2 {
    font-size: 28px;
    margin-bottom: 8px;
  }

  .register-panel-header p {
    color: var(--text-secondary);
    font-size: 15px;
    margin: 0;
  }

  .field-group {
    margin-bottom: 18px;
  }

  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .field-card {
    position: relative;
    padding: 18px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-xl);
    background: var(--bg-elevated);
    transition: all var(--duration-normal) var(--ease-out);
    cursor: pointer;
  }

  .field-card.active {
    border-color: var(--brand);
    box-shadow: 0 0 0 1px var(--brand-subtle), 0 0 16px var(--brand-glow);
  }

  .field-card h3 {
    font-size: 18px;
    margin-bottom: 6px;
  }

  .field-card p {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }

  .choice-radio {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .input-stack {
    display: grid;
    gap: 14px;
  }

  .inline-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: end;
  }

  .captcha-row {
    display: grid;
    grid-template-columns: 1fr 132px auto;
    gap: 12px;
    align-items: end;
  }

  .captcha-box {
    min-width: 120px;
    height: 56px;
    background: var(--surface-strong);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .captcha-box img {
    display: block;
    width: 120px;
    height: 50px;
    user-select: none;
  }

  .section-block {
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-elevated);
    margin-top: 18px;
  }

  .section-block h4 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-block p {
    margin: 0 0 16px;
    color: var(--text-secondary);
    font-size: 14px;
  }

  .email-toggle {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-full);
    background: var(--surface-strong);
    color: var(--text-soft);
    cursor: pointer;
    margin-top: 2px;
    transition: all var(--duration-fast) ease;
  }

  .email-toggle:hover {
    border-color: var(--border-hover);
    background: var(--surface-hover);
  }

  .email-toggle input {
    width: 16px;
    height: 16px;
    margin: 0;
    accent-color: var(--brand);
  }

  .subtle-note {
    margin-top: 10px;
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .form-message {
    margin-bottom: 16px;
    padding: 14px 16px;
    border-radius: var(--radius-lg);
    background: rgba(249, 112, 102, 0.1);
    border: 1px solid rgba(249, 112, 102, 0.2);
    color: #fca5a0;
    line-height: 1.6;
  }

  .btn-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #7c5cfc 0%, #9178ff 100%);
    border-color: rgba(124, 92, 252, 0.4);
    box-shadow: 0 2px 12px rgba(124, 92, 252, 0.3);
    color: #fff;
  }

  .btn-brand:hover {
    box-shadow: 0 4px 20px rgba(124, 92, 252, 0.4);
  }

  .btn-soft {
    background: var(--surface-strong);
    border-color: var(--border-strong);
    box-shadow: none;
    color: var(--text-soft);
  }

  .btn-soft:hover {
    background: var(--surface-hover);
    border-color: var(--border-hover);
    box-shadow: none;
  }

  .submit-wrap {
    margin-top: 24px;
  }

  .submit-wrap button {
    padding: 14px 18px;
    font-size: 15px;
    border-radius: var(--radius-lg);
  }

  @media (max-width: 980px) {
    .register-shell {
      grid-template-columns: 1fr;
    }
    .register-hero {
      min-height: auto;
      padding: 28px;
    }
  }

  @media (max-width: 720px) {
    .field-grid,
    .inline-row,
    .captcha-row {
      grid-template-columns: 1fr;
    }
    .register-panel,
    .register-hero {
      border-radius: var(--radius-xl);
      padding: 20px;
    }
  }
</style>
<div class="register-shell">
  <section class="register-hero">
    <div>
      <div class="register-kicker">Register</div>
      <h1>注册账号</h1>
      <p>按你的地区选择注册方式：国内用户使用手机号验证，国外用户使用邮箱验证。</p>
      <p>国内默认展示手机号流程；邮箱区域按需展开。国外模式会直接显示邮箱验证区域。</p>
    </div>

    <div class="register-hero-list">
      <div class="register-hero-item">
        <strong>国内用户</strong>
        <span>填写手机号、图形验证码和短信验证码后完成注册。</span>
      </div>
      <div class="register-hero-item">
        <strong>国外用户</strong>
        <span>仅支持常见主流邮箱域名，通过邮箱验证码完成注册。</span>
      </div>
      <div class="register-hero-item">
        <strong>账号信息</strong>
        <span>用户名和密码为必填项，注册后可直接登录并开始使用。</span>
      </div>
    </div>
  </section>

  <section class="register-panel">
    <div class="register-panel-header">
      <h2>创建账号</h2>
      <p>先选择注册地区，再完成对应验证。</p>
    </div>

    <% if (formMessage) { %>
      <div class="form-message"><%= formMessage %></div>
    <% } %>

    <form method="POST" action="/register">
      <div class="field-grid">
        <div class="field-group">
          <label for="username">用户名</label>
          <input id="username" name="username" maxlength="50" required placeholder="至少 3 位" value="<%= form.username || '' %>" />
        </div>
        <div class="field-group">
          <label for="password">密码</label>
          <input id="password" name="password" type="password" maxlength="100" required placeholder="至少 6 位" />
        </div>
      </div>

      <div class="field-group">
        <label>用户地区</label>
        <div class="field-grid">
          <label class="field-card active" id="domesticCard">
            <input class="choice-radio" type="radio" name="countryType" value="domestic" <%= (form.countryType || 'domestic') === 'domestic' ? 'checked' : '' %> onchange="handleCountryChange()" />
            <h3>国内用户</h3>
            <p>手机号为必填项，先过图形验证码，再发送正式短信验证码。</p>
          </label>
          <label class="field-card" id="internationalCard">
            <input class="choice-radio" type="radio" name="countryType" value="international" <%= (form.countryType || 'domestic') === 'international' ? 'checked' : '' %> onchange="handleCountryChange()" />
            <h3>国外用户</h3>
            <p>使用主流邮箱注册与登录，不走国内号码认证服务。</p>
          </label>
        </div>
      </div>

      <div id="phoneBlock" class="section-block">
        <h4>国内手机号验证</h4>
        <p id="numberAuthHint">已接入阿里云图形认证 / 号码认证参数，当前先以图形验证码 + 正式短信验证码为主流程。</p>
        <div class="input-stack">
          <div class="field-group">
            <label for="phone">手机号</label>
            <input name="phone" id="phone" maxlength="30" placeholder="请输入国内手机号" value="<%= form.phone || '' %>" />
          </div>
          <div class="field-group">
            <label for="captchaText">图形验证码</label>
            <input type="hidden" name="captchaId" value="<%= captcha.captchaId %>" />
            <div class="captcha-row">
              <input id="captchaText" name="captchaText" maxlength="10" placeholder="输入图形验证码" autocomplete="off" />
              <div class="captcha-box">
                <img id="captchaImage" src="<%= captcha.imageUrl %>" alt="图形验证码" />
              </div>
              <button class="btn-soft" type="button" onclick="refreshCaptcha('已刷新图形验证码，请输入新的验证码。')">刷新验证码</button>
            </div>
            <div class="subtle-note" id="captchaHint">发送验证码后，图形验证码会自动刷新，你需要输入新的验证码。</div>
          </div>

          <div class="field-group">
            <label for="phoneCode">短信验证码</label>
            <div class="inline-row">
              <input id="phoneCode" name="phoneCode" maxlength="6" placeholder="输入 6 位短信验证码" />
              <button class="btn-soft" type="button" onclick="sendPhoneCode()">发送短信验证码</button>
            </div>
          </div>
        </div>
      </div>

      <div class="field-group" id="emailToggleWrap">
        <label class="email-toggle">
          <input type="checkbox" id="showEmailToggle" <%= form.showEmailToggle ? 'checked' : '' %> onchange="toggleEmailBlock()" />
          <span>显示邮箱注册项</span>
        </label>
        <div class="subtle-note">国内用户可选填邮箱；国外用户会直接显示邮箱区。</div>
      </div>

      <div id="emailBlock" class="section-block" style="display:<%= (form.countryType === 'international' || form.showEmailToggle) ? 'block' : 'none' %>;">
        <h4>邮箱验证</h4>
        <p>海外注册仅支持主流邮箱域名。国内用户如果想额外绑定邮箱，也可以在这里操作。</p>
        <div class="input-stack">
          <div class="field-group">
            <label for="email">邮箱</label>
            <input name="email" id="email" maxlength="120" placeholder="Gmail / Outlook / Hotmail / iCloud / Yahoo / Proton" value="<%= form.email || '' %>" />
          </div>

          <div class="field-group">
            <label for="emailCode">邮箱验证码</label>
            <div class="inline-row">
              <input id="emailCode" name="emailCode" maxlength="6" placeholder="输入 6 位邮箱验证码" />
              <button class="btn-soft" type="button" onclick="sendEmailCode()">发送邮箱验证码</button>
            </div>
          </div>
        </div>
      </div>

      <div class="submit-wrap">
        <button class="btn-brand" type="submit">完成注册</button>
      </div>
    </form>
  </section>
</div>
<script src="/public/vendor/ct4.js"></script>
<script src="/public/vendor/numberAuth-web-sdk.js"></script>
<script>
  window.AI_ROLEPLAY_AUTH_CONFIG = {
    graphAuthAppId: '<%= authConfig.graphAuthAppId %>',
    graphAuthAppKey: '<%= authConfig.graphAuthAppKey %>',
    numberAuthSchemeCode: '<%= authConfig.numberAuthSchemeCode %>'
  };
</script>

<script>
  function getCountryType() {
    const checked = document.querySelector('input[name="countryType"]:checked');
    return checked ? checked.value : 'domestic';
  }

  function syncCountryCards(countryType) {
    const domesticCard = document.getElementById('domesticCard');
    const internationalCard = document.getElementById('internationalCard');
    domesticCard.classList.toggle('active', countryType === 'domestic');
    internationalCard.classList.toggle('active', countryType === 'international');
  }

  function handleCountryChange() {
    const countryType = getCountryType();
    const phoneBlock = document.getElementById('phoneBlock');
    const emailBlock = document.getElementById('emailBlock');
    const emailToggle = document.getElementById('showEmailToggle');
    const emailToggleWrap = document.getElementById('emailToggleWrap');
    const numberAuthHint = document.getElementById('numberAuthHint');

    syncCountryCards(countryType);

    if (countryType === 'domestic') {
      phoneBlock.style.display = 'block';
      emailToggleWrap.style.display = 'block';
      emailBlock.style.display = emailToggle.checked ? 'block' : 'none';
      numberAuthHint.style.display = 'block';
    } else {
      phoneBlock.style.display = 'none';
      emailBlock.style.display = 'block';
      emailToggle.checked = true;
      emailToggleWrap.style.display = 'none';
      numberAuthHint.style.display = 'none';
    }
  }

  function toggleEmailBlock() {
    const countryType = getCountryType();
    const emailBlock = document.getElementById('emailBlock');
    const emailToggle = document.getElementById('showEmailToggle');
    if (countryType === 'domestic') {
      emailBlock.style.display = emailToggle.checked ? 'block' : 'none';
    }
  }
  function showCaptchaHint(message) {
    const hint = document.getElementById('captchaHint');
    if (hint) {
      hint.textContent = message;
    }
  }

  async function refreshCaptcha(message) {
    const captchaIdInput = document.querySelector('input[name="captchaId"]');
    const captchaTextInput = document.getElementById('captchaText');
    const previousCaptchaId = captchaIdInput.value;
    const res = await fetch('/api/captcha?previousCaptchaId=' + encodeURIComponent(previousCaptchaId));
    const data = await res.json();
    captchaIdInput.value = data.captchaId;
    document.getElementById('captchaImage').src = data.imageUrl + '?t=' + Date.now();
    captchaTextInput.value = '';
    showCaptchaHint(message || '图形验证码已刷新，请输入新的验证码。');
    captchaTextInput.focus();
  }

  function applyCaptchaRefreshFromResponse(data, fallbackMessage) {
    if (!data || !data.nextCaptchaId || !data.nextCaptchaImageUrl) {
      return;
    }
    document.querySelector('input[name="captchaId"]').value = data.nextCaptchaId;
    document.getElementById('captchaImage').src = data.nextCaptchaImageUrl + '?t=' + Date.now();
    const captchaTextInput = document.getElementById('captchaText');
    captchaTextInput.value = '';
    showCaptchaHint(data.message || fallbackMessage || '图形验证码已刷新，请输入新的验证码。');
    captchaTextInput.focus();
  }

  async function sendEmailCode() {
    const email = document.getElementById('email').value.trim();
    const captchaId = document.querySelector('input[name="captchaId"]').value;
    const captchaText = document.getElementById('captchaText').value.trim();
    if (!email) {
      alert('先填邮箱');
      return;
    }
    if (!captchaId || !captchaText) {
      alert('先填图形验证码');
      return;
    }

    const res = await fetch('/api/send-email-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, countryType: getCountryType(), captchaId, captchaText })
    });
    const data = await res.json();
    applyCaptchaRefreshFromResponse(data, '邮箱验证码处理完成，请输入新的图形验证码。');
    alert(data.message || '已发送');
  }

  async function sendPhoneCode() {
    const phone = document.getElementById('phone').value.trim();
    const captchaId = document.querySelector('input[name="captchaId"]').value;
    const captchaText = document.querySelector('input[name="captchaText"]').value.trim();
    if (!phone || !captchaId || !captchaText) {
      alert('先填手机号和图形验证码');
      return;
    }

    const res = await fetch('/api/send-phone-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone, captchaId, captchaText })
    });
    const data = await res.json();
    applyCaptchaRefreshFromResponse(data, '短信验证码处理完成，请输入新的图形验证码。');
    alert(data.message || '已发送');
  }

  handleCountryChange();
</script>
