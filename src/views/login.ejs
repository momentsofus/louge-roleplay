<!-- @file src/views/login.ejs
     @description 登录页模板。调用说明：GET /login 渲染，POST /login 校验用户名/邮箱/手机号与密码。
-->
<link rel="stylesheet" href="/public/styles/shared-feedback.css" />

<div class="feedback-shell feedback-shell--compact">
  <div class="feedback-card">
    <h1 class="feedback-title">欢迎回来</h1>
    <p class="feedback-copy">继续你上次没聊完的话。你可以用用户名、邮箱或者手机号登录。</p>
    <form method="POST" action="/login">
      <div class="feedback-field-group">
        <label for="login">账号</label>
        <input id="login" name="login" maxlength="120" required placeholder="用户名 / 邮箱 / 手机号" />
      </div>
      <div class="feedback-field-group">
        <label for="password">密码</label>
        <input id="password" name="password" type="password" maxlength="100" required placeholder="输入密码" />
      </div>
      <button class="feedback-submit-btn" type="submit">登录</button>
    </form>
    <div class="feedback-foot-note">第一次来？<a href="/register">注册账号 →</a></div>
  </div>
</div>