<!-- @file src/views/character-new.ejs
     @description 角色创建/编辑共用模板。调用说明：GET /characters/new 与 GET /characters/:id/edit 渲染，public/js/character-editor-page.js 管理动态提示词字段。
-->
<div class="editor-shell">
  <div class="editor-card">
    <h1><%= mode === 'edit' ? '编辑角色' : '创建角色' %></h1>
    <p>这里用于配置角色基础资料、行为设定、展示信息和开场白。保存前可预览最终规则。</p>

    <div class="hint-card">
      <strong>角色配置说明</strong>
      <ul>
        <li><strong>影响角色表现：</strong>角色名、一句话简介、身份定位、性格描述、当前场景、背景信息，以及已启用的补充规则。</li>
        <li><strong>不影响角色表现：</strong>开场白、空字段和已停用的补充规则不会影响角色表现。</li>
        <li><strong>规则预览：</strong>下方预览会按最终顺序展示角色配置内容，便于保存前检查一致性。</li>
      </ul>
    </div>

    <form method="POST" action="<%= mode === 'edit' ? `/characters/${character.id}/edit` : '/characters/new' %>" id="character-form" enctype="multipart/form-data">
      <div class="field-group">
        <label for="name">角色名</label>
        <input id="name" name="name" maxlength="5000" placeholder="比如：沈砚、阿迟、旧书店老板" value="<%= form?.name || '' %>" />
      </div>

      <div class="field-group">
        <label for="summary">一句话简介</label>
        <textarea id="summary" name="summary" maxlength="5000" placeholder="用一句话说明角色定位，保持准确、简洁。"><%= form?.summary || '' %></textarea>
        <div class="mini-note">填写后会参与角色表现；留空则跳过。</div>
      </div>

      <div class="field-group">
        <label for="role">角色</label>
        <textarea id="role" name="role" maxlength="5000" placeholder="写清身份、定位，以及和用户之间的关系。"><%= form?.role || '' %></textarea>
        <div class="mini-note">填写后会参与角色表现；留空则跳过。</div>
      </div>

      <div class="field-group large">
        <label for="traitDescription">描述角色性格</label>
        <textarea id="traitDescription" name="traitDescription" maxlength="5000" placeholder="说明角色性格、表达方式、行为边界和习惯，尽量保持结构清晰。"><%= form?.traitDescription || '' %></textarea>
        <div class="mini-note">填写后会参与角色表现；留空则跳过。</div>
      </div>

      <div class="field-group">
        <label for="currentScene">当前场景</label>
        <textarea id="currentScene" name="currentScene" maxlength="5000" placeholder="写此刻角色和用户正在经历的场景。"><%= form?.currentScene || '' %></textarea>
        <div class="mini-note">填写后会参与角色表现；留空则跳过。</div>
      </div>

      <div class="field-group">
        <label for="currentBackground">当前背景</label>
        <textarea id="currentBackground" name="currentBackground" maxlength="5000" placeholder="写支撑当前场景的背景、前情与关系变化。"><%= form?.currentBackground || '' %></textarea>
        <div class="mini-note">填写后会参与角色表现；留空则跳过。</div>
      </div>

      <div class="field-group tag-field-group">
        <label for="tags">标签</label>
        <input id="tags" name="tags" data-tag-input maxlength="5000" placeholder="输入标签后按回车，比如：奇幻、治愈、日常" value="<%= form?.tagsText || '' %>" />
        <div class="mini-note">输入后按 Enter 或逗号生成标签；会自动去重、去掉 # 号，最多保留 12 个。公开角色大厅可以按“包含任一 / 包含全部”搜索。</div>
      </div>

      <div class="field-group">
        <label for="visibility">是否公开</label>
        <select id="visibility" name="visibility">
          <option value="public" <%= (form?.visibility || 'public') === 'public' ? 'selected' : '' %>>公开（会出现在公开角色页）</option>
          <option value="private" <%= (form?.visibility || 'public') === 'private' ? 'selected' : '' %>>私有（只有我自己能看到和使用）</option>
        </select>
        <div class="mini-note">公开角色会显示在公开角色页；私有角色只保留在你的控制台里，别人不能直接开始对话。</div>
      </div>

      <div class="field-group">
        <label for="isNsfw">NSFW 选项</label>
        <select id="isNsfw" name="isNsfw">
          <option value="0" <%= form?.isNsfw ? '' : 'selected' %>>否</option>
          <option value="1" <%= form?.isNsfw ? 'selected' : '' %>>是，默认不在公共角色大厅显示</option>
        </select>
        <div class="mini-note">NSFW 角色默认从公共列表隐藏；登录并开启显示后才会出现在公开角色中。</div>
      </div>

      <div class="media-upload-grid">
        <div class="field-group upload-field">
          <label for="avatarImage">角色头像（可选）</label>
          <% if (form?.avatarImagePath) { %>
            <div class="upload-preview upload-preview--avatar">
              <img src="<%= form.avatarImagePath %>" alt="当前角色头像" />
            </div>
          <% } %>
          <input id="avatarImage" name="avatarImage" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <div class="mini-note"><%= t('可选；不上传就不显示头像。重新上传会替换旧头像。支持 jpg/png/webp/gif，单图不超过 3MB。') %></div>
        </div>

        <div class="field-group upload-field">
          <label for="backgroundImage">对话背景图（可选）</label>
          <% if (form?.backgroundImagePath) { %>
            <div class="upload-preview upload-preview--background">
              <img src="<%= form.backgroundImagePath %>" alt="当前对话背景图" />
            </div>
          <% } %>
          <input id="backgroundImage" name="backgroundImage" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <div class="mini-note">不上传就保持现在的默认聊天背景；重新上传会替换旧背景。建议横图，单图不超过 3MB。</div>
        </div>
      </div>

      <div class="field-group large">
        <label for="firstMessage">开场白</label>
        <textarea id="firstMessage" name="firstMessage" maxlength="5000" placeholder="这是新对话开始时，角色主动发出的第一句话。"><%= form?.firstMessage || '' %></textarea>
        <div class="mini-note">只在新对话开始时使用。填写后，角色会以这句话作为第一条消息。</div>
      </div>
      <div class="field-group">
        <label>补充规则</label>
        <div class="mini-note">这里用于补充设定或特殊要求。支持拖动排序；空内容和停用项会自动忽略。</div>
        <div class="drag-tip">拖住每一块就能改顺序；下面的预览会实时更新。</div>
      </div>

      <div id="prompt-items">
        <% (extraPromptItems || []).forEach((item, index) => { %>
          <div class="prompt-item" draggable="true">
            <div class="prompt-grid">
              <label>
                key
                <input type="text" name="extraPromptItemKey" maxlength="5000" value="<%= item.key %>" placeholder="比如：禁忌 / 世界规则 / 特殊要求" />
              </label>
              <label>
                value
                <textarea name="extraPromptItemValue" rows="4" maxlength="5000" placeholder="写这个补充片段的内容"><%= item.value %></textarea>
              </label>
              <label>
                启用
                <select name="extraPromptItemEnabled">
                  <option value="1" <%= item.isEnabled ? 'selected' : '' %>>启用</option>
                  <option value="0" <%= item.isEnabled ? '' : 'selected' %>>停用</option>
                </select>
              </label>
            </div>
            <div class="prompt-actions">
              <button type="button" class="ghost-btn" data-action="remove">删除这项</button>
              <span class="mini-note">当前顺序：<span data-order><%= index + 1 %></span></span>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="prompt-actions">
        <button class="ghost-btn" type="button" id="add-prompt-item">新增额外片段</button>
        <button class="ghost-btn" type="button" id="preview-character-prompt">刷新预览</button>
      </div>

      <div id="character-prompt-preview" class="preview-box live"></div>

      <button class="submit-btn" type="submit"><%= mode === 'edit' ? '保存角色' : '创建角色' %></button>
    </form>

    <% if (mode === 'edit' && character) { %>
      <section class="hint-card character-start-card">
        <strong><%= t('想重新开始？') %></strong>
        <p class="mini-note"><%= t('开启新对话会创建一条全新的独立会话，不会带入这个角色之前的聊天内容。') %></p>
        <form method="POST" action="/conversations/start/<%= character.id %>">
          <button type="submit" class="btn-brand"><%= t('开启新对话') %></button>
        </form>
      </section>
    <% } %>

    <% if (mode === 'edit' && character) { %>
      <section class="danger-zone">
        <h3>危险操作</h3>
        <p>为保护已有会话，现在只允许删除从未开始过对话的角色。已经产生会话的角色会先保留，避免误删关联内容。</p>
        <div class="prompt-actions">
          <form method="POST" action="/characters/<%= character.id %>/delete" data-confirm-message="确认删除这个角色吗？只有从未开过对话的角色才能删除。">
            <button type="submit" class="ghost-btn danger-btn">删除这个角色</button>
          </form>
        </div>
      </section>
    <% } %>
  </div>
</div>
<script nonce="<%= cspNonce || '' %>" src="/public/js/character-editor-page.js?v=v1.4.3-20260506"></script>
