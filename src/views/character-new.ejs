<style>
  .editor-shell {
    max-width: 960px;
    margin: 0 auto;
    animation: fadeIn var(--duration-slow) var(--ease-out) both;
  }

  .editor-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    padding: 32px;
    box-shadow: var(--shadow-md);
  }

  .editor-card h1 {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .editor-card > p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 24px;
    font-size: 15px;
  }

  .field-group {
    margin-bottom: 18px;
  }

  .field-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .field-group.large textarea {
    min-height: 180px;
  }

  .hint-card {
    background: rgba(96, 165, 250, 0.06);
    border: 1px solid rgba(96, 165, 250, 0.12);
    border-radius: var(--radius-lg);
    padding: 18px;
    margin-bottom: 24px;
  }

  .hint-card strong {
    display: block;
    margin-bottom: 8px;
    color: var(--accent-blue);
    font-size: 14px;
  }

  .hint-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 14px;
  }

  .hint-card code {
    background: rgba(255, 255, 255, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--brand-hover);
  }

  .prompt-item {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 18px;
    background: var(--bg-elevated);
    margin-bottom: 14px;
    cursor: grab;
    transition: all var(--duration-fast) ease;
  }

  .prompt-item:hover {
    border-color: var(--border-hover);
  }

  .prompt-item.dragging {
    opacity: 0.5;
    border-color: var(--brand);
    box-shadow: 0 0 12px var(--brand-glow);
  }

  .prompt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 120px;
    gap: 12px;
    align-items: end;
  }

  .mini-note {
    color: var(--text-tertiary);
    font-size: 13px;
    line-height: 1.6;
    margin-top: 8px;
  }

  .prompt-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .submit-btn {
    margin-top: 16px;
    width: 100%;
    padding: 14px 18px;
    font-size: 15px;
  }

  .ghost-btn {
    margin-top: 10px;
    background: var(--surface-strong);
    color: var(--text-soft);
    border-color: var(--border-strong);
    box-shadow: none;
  }

  .ghost-btn:hover {
    background: var(--surface-hover);
    border-color: var(--border-hover);
    box-shadow: none;
  }

  .preview-box {
    white-space: pre-wrap;
    line-height: 1.7;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px;
    margin-top: 16px;
    font-family: 'SFMono-Regular', Consolas, 'Courier New', monospace;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .preview-box.live::before {
    content: '实时预览（将进入提示词）';
    display: inline-block;
    margin-bottom: 12px;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    background: var(--brand-subtle);
    color: var(--brand-hover);
    font-size: 12px;
    font-family: inherit;
  }

  .danger-zone {
    margin-top: 26px;
    padding: 18px;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(249, 112, 102, 0.22);
    background: rgba(249, 112, 102, 0.07);
  }

  .danger-zone h3 {
    margin: 0 0 8px;
    font-size: 16px;
    color: #ffd7d2;
  }

  .danger-zone p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 14px;
  }

  .danger-zone .prompt-actions {
    margin-top: 14px;
  }

  .danger-btn {
    margin-top: 0;
    background: rgba(249, 112, 102, 0.14);
    color: #ffd7d2;
    border-color: rgba(249, 112, 102, 0.28);
    box-shadow: none;
  }

  .danger-btn:hover {
    background: rgba(249, 112, 102, 0.2);
    border-color: rgba(249, 112, 102, 0.42);
    box-shadow: none;
  }

  .drag-tip {
    margin-top: 6px;
    color: var(--text-tertiary);
    font-size: 12px;
  }

  @media (max-width: 800px) {
    .prompt-grid {
      grid-template-columns: 1fr;
    }
    .editor-card {
      padding: 22px;
    }
  }
</style>
<div class="editor-shell">
  <div class="editor-card">
    <h1><%= mode === 'edit' ? '编辑角色' : '创建角色' %></h1>
    <p>这页不再写那种太虚的描述了。下面这些字段里，哪些会进提示词、怎么进，我都直接摊开给你看。</p>

    <div class="hint-card">
      <strong>提示词规则</strong>
      <ul>
        <li><strong>会进入提示词：</strong>角色名、一句话简介、角色、描述角色性格、当前场景、当前背景、以及你额外添加并启用的片段。</li>
        <li><strong>不会进入提示词：</strong>开场白、留空的字段、被你手动停用的额外片段。</li>
        <li><strong>进入方式：</strong>统一按 <code>【[key]】{ value }</code> 拼接到 system prompt 里，下面预览看到的基本就是实际喂给模型的样子。</li>
      </ul>
    </div>

    <form method="POST" action="<%= mode === 'edit' ? `/characters/${character.id}/edit` : '/characters/new' %>" id="character-form">
      <div class="field-group">
        <label for="name">角色名</label>
        <input id="name" name="name" maxlength="100" placeholder="比如：沈砚、阿迟、旧书店老板" value="<%= form?.name || '' %>" />
      </div>

      <div class="field-group">
        <label for="summary">一句话简介</label>
        <textarea id="summary" name="summary" maxlength="500" placeholder="会进入提示词。用于一句话说明这是谁，不写废话。"><%= form?.summary || '' %></textarea>
        <div class="mini-note">会作为 `【[角色简介]】{ ... }` 进入提示词；留空就不拼接。</div>
      </div>

      <div class="field-group">
        <label for="role">角色</label>
        <textarea id="role" name="role" maxlength="1200" placeholder="会进入提示词。写清身份、定位、和用户的关系。"><%= form?.role || '' %></textarea>
        <div class="mini-note">会作为 `【[角色]】{ ... }` 进入提示词；留空就不拼接。</div>
      </div>

      <div class="field-group large">
        <label for="traitDescription">描述角色性格</label>
        <textarea id="traitDescription" name="traitDescription" maxlength="3000" placeholder="会进入提示词。写性格、说话方式、边界、习惯，不要写成散漫设定集。"><%= form?.traitDescription || '' %></textarea>
        <div class="mini-note">会作为 `【[描述角色性格]】{ ... }` 进入提示词；留空就不拼接。</div>
      </div>

      <div class="field-group">
        <label for="currentScene">当前场景</label>
        <textarea id="currentScene" name="currentScene" maxlength="2000" placeholder="会进入提示词。写此刻角色和用户所处的即时场景。"><%= form?.currentScene || '' %></textarea>
        <div class="mini-note">会作为 `【[当前场景]】{ ... }` 进入提示词；留空就不拼接。</div>
      </div>

      <div class="field-group">
        <label for="currentBackground">当前背景</label>
        <textarea id="currentBackground" name="currentBackground" maxlength="2500" placeholder="会进入提示词。写支撑当前场景的背景信息、上下文、前情。"><%= form?.currentBackground || '' %></textarea>
        <div class="mini-note">会作为 `【[当前背景]】{ ... }` 进入提示词；留空就不拼接。</div>
      </div>

      <div class="field-group">
        <label for="visibility">是否公开</label>
        <select id="visibility" name="visibility">
          <option value="public" <%= (form?.visibility || 'public') === 'public' ? 'selected' : '' %>>公开（会出现在首页公开角色列表）</option>
          <option value="private" <%= (form?.visibility || 'public') === 'private' ? 'selected' : '' %>>私有（只有我自己能看到和使用）</option>
        </select>
        <div class="mini-note">公开角色会显示在首页；私有角色只保留在你的控制台里，别人不能直接开始对话。</div>
      </div>

      <div class="field-group large">
        <label for="firstMessage">开场白</label>
        <textarea id="firstMessage" name="firstMessage" maxlength="2000" placeholder="这句不会写入 system 提示词，只会在首次开始对话时作为角色发出的第一句。"><%= form?.firstMessage || '' %></textarea>
        <div class="mini-note">不会进入提示词。仅当用户首次开始这段对话时使用：若填写了开场白，系统会先记一条用户消息 `［开始一次新的对话］`，再由角色发出这句开场白。</div>
      </div>
      <div class="field-group">
        <label>额外提示词片段</label>
        <div class="mini-note">这里只放补充信息。支持拖动排序。空值会自动跳过，停用就不会进提示词。</div>
        <div class="drag-tip">拖住每一块就能改顺序；下面的预览会实时更新。</div>
      </div>

      <div id="prompt-items">
        <% (extraPromptItems || []).forEach((item, index) => { %>
          <div class="prompt-item" draggable="true">
            <div class="prompt-grid">
              <label>
                key
                <input type="text" name="extraPromptItemKey" value="<%= item.key %>" placeholder="比如：禁忌 / 世界规则 / 特殊要求" />
              </label>
              <label>
                value
                <textarea name="extraPromptItemValue" rows="4" placeholder="写这个补充片段的内容"><%= item.value %></textarea>
              </label>
              <label>
                启用
                <select name="extraPromptItemEnabled">
                  <option value="1" <%= item.isEnabled ? 'selected' : '' %>>启用</option>
                  <option value="0" <%= item.isEnabled ? '' : 'selected' %>>停用</option>
                </select>
              </label>
            </div>
            <div class="prompt-actions">
              <button type="button" class="ghost-btn" data-action="remove">删除这项</button>
              <span class="mini-note">当前顺序：<span data-order><%= index + 1 %></span></span>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="prompt-actions">
        <button class="ghost-btn" type="button" id="add-prompt-item">新增额外片段</button>
        <button class="ghost-btn" type="button" id="preview-character-prompt">刷新预览</button>
      </div>

      <div id="character-prompt-preview" class="preview-box live"></div>

      <button class="submit-btn" type="submit"><%= mode === 'edit' ? '保存角色' : '创建角色' %></button>
    </form>

    <% if (mode === 'edit' && character) { %>
      <section class="danger-zone">
        <h3>危险操作</h3>
        <p>删除角色会先走后端安全校验。现在只允许删除“还没有任何对话记录”的角色；只要这个角色已经开过对话，就会被拦住，避免把分支会话整串误删。</p>
        <div class="prompt-actions">
          <form method="POST" action="/characters/<%= character.id %>/delete" onsubmit="return confirm('确认删除这个角色吗？只有从未开过对话的角色才能删除。');">
            <button type="submit" class="ghost-btn danger-btn">删除这个角色</button>
          </form>
        </div>
      </section>
    <% } %>
  </div>
</div>
<script>
  (function () {
    const container = document.getElementById('prompt-items');
    const addButton = document.getElementById('add-prompt-item');
    const previewButton = document.getElementById('preview-character-prompt');
    const previewBox = document.getElementById('character-prompt-preview');
    let dragging = null;

    const structuredFields = [
      ['角色名', 'name'],
      ['角色简介', 'summary'],
      ['角色', 'role'],
      ['描述角色性格', 'traitDescription'],
      ['当前场景', 'currentScene'],
      ['当前背景', 'currentBackground'],
    ];

    function refreshOrders() {
      Array.from(container.querySelectorAll('.prompt-item')).forEach((item, index) => {
        const orderNode = item.querySelector('[data-order]');
        if (orderNode) orderNode.textContent = index + 1;
      });
    }

    function renderPreview() {
      const sections = structuredFields.map(([label, fieldId]) => {
        const field = document.getElementById(fieldId);
        const value = field?.value?.trim() || '';
        if (!value) return '';
        return `【[${label}]】{\n${value}\n}`;
      }).filter(Boolean);

      const extraItems = Array.from(container.querySelectorAll('.prompt-item')).map((item) => {
        const key = item.querySelector('input[name="extraPromptItemKey"]')?.value?.trim() || '';
        const value = item.querySelector('textarea[name="extraPromptItemValue"]')?.value?.trim() || '';
        const enabled = item.querySelector('select[name="extraPromptItemEnabled"]')?.value !== '0';
        if (!enabled || !value) return '';
        return `【[${key || '未命名片段'}]】{\n${value}\n}`;
      }).filter(Boolean);

      previewBox.textContent = [...sections, ...extraItems].join('\n\n') || '当前没有可拼接的角色提示词。';
    }

    function bindItem(item) {
      item.addEventListener('dragstart', () => {
        dragging = item;
        item.classList.add('dragging');
      });
      item.addEventListener('dragend', () => {
        item.classList.remove('dragging');
        dragging = null;
        refreshOrders();
        renderPreview();
      });
      item.addEventListener('dragover', (event) => {
        event.preventDefault();
        if (!dragging || dragging === item) return;
        const rect = item.getBoundingClientRect();
        const shouldInsertAfter = event.clientY > rect.top + rect.height / 2;
        if (shouldInsertAfter) item.after(dragging);
        else item.before(dragging);
      });
      const removeButton = item.querySelector('[data-action="remove"]');
      Array.from(item.querySelectorAll('input, textarea, select')).forEach((field) => {
        field.addEventListener('input', renderPreview);
        field.addEventListener('change', renderPreview);
      });
      if (removeButton) {
        removeButton.addEventListener('click', () => {
          item.remove();
          refreshOrders();
          renderPreview();
        });
      }
    }

    function createItem() {
      const wrapper = document.createElement('div');
      wrapper.className = 'prompt-item';
      wrapper.draggable = true;
      wrapper.innerHTML = `
        <div class="prompt-grid">
          <label>
            key
            <input type="text" name="extraPromptItemKey" placeholder="比如：禁忌 / 世界规则 / 特殊要求" />
          </label>
          <label>
            value
            <textarea name="extraPromptItemValue" rows="4" placeholder="写这个补充片段的内容"></textarea>
          </label>
          <label>
            启用
            <select name="extraPromptItemEnabled">
              <option value="1" selected>启用</option>
              <option value="0">停用</option>
            </select>
          </label>
        </div>
        <div class="prompt-actions">
          <button type="button" class="ghost-btn" data-action="remove">删除这项</button>
          <span class="mini-note">当前顺序：<span data-order></span></span>
        </div>
      `;
      bindItem(wrapper);
      return wrapper;
    }

    Array.from(container.querySelectorAll('.prompt-item')).forEach(bindItem);
    refreshOrders();

    structuredFields.forEach(([, fieldId]) => {
      const field = document.getElementById(fieldId);
      if (!field) return;
      field.addEventListener('input', renderPreview);
      field.addEventListener('change', renderPreview);
    });

    addButton.addEventListener('click', () => {
      container.appendChild(createItem());
      refreshOrders();
      renderPreview();
    });

    previewButton.addEventListener('click', renderPreview);

    renderPreview();
  })();
</script>
