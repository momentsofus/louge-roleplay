<style>
  .message-shell {
    max-width: 560px;
    margin: 48px auto 0;
    animation: scaleIn var(--duration-slow) var(--ease-out) both;
  }

  .message-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    padding: 36px;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .message-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #60a5fa, #93c5fd);
  }

  .message-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: rgba(96, 165, 250, 0.1);
    border: 1px solid rgba(96, 165, 250, 0.2);
    color: var(--accent-blue);
    font-size: 12px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .message-card h1 {
    font-size: 32px;
    line-height: 1.25;
    margin-bottom: 14px;
    color: var(--text);
  }

  .message-card p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 22px;
    font-size: 15px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: var(--radius-full);
    background: var(--surface-strong);
    border: 1px solid var(--border-strong);
    color: var(--text-soft);
    transition: all var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .back-link:hover {
    border-color: var(--brand);
    color: var(--brand-hover);
    box-shadow: 0 0 0 1px var(--brand-subtle);
  }

  .back-link::before {
    content: '←';
    font-size: 15px;
  }
</style>

<div class="message-shell">
  <div class="message-card">
    <div class="message-kicker">Notice</div>
    <h1>先停一下</h1>
    <p><%= message %></p>
    <a class="back-link" href="/">回到首页</a>
  </div>
</div>
