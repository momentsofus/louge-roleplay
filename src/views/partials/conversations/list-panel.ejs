<section class="panel dashboard-section conversation-manager-panel">
  <form id="conversationBulkForm" method="post" action="/conversations/bulk" data-conversation-bulk-form>
    <input type="hidden" name="returnTo" value="<%= currentUrl %>" />
    <div class="section-heading dashboard-section-heading conversation-list-heading">
      <div>
        <div class="section-kicker">List</div>
        <h2><%= t('全部对话') %></h2>
        <p><%= t('当前筛选共') %> <strong><%= formatConversationCount(result.total || 0) %></strong> <%= t('条，正在查看第') %> <%= page %> / <%= totalPages %> <%= t('页。') %></p>
      </div>
      <div class="toolbar-row toolbar-row--admin conversation-bulk-actions">
        <label class="toolbar-row toolbar-row--tight toolbar-row--checkbox conversation-select-all">
          <input type="checkbox" data-conversation-select-all />
          <span><%= t('全选本页') %></span>
        </label>
        <button class="inline-btn" type="submit" name="action" value="archive" data-bulk-action data-confirm-message="<%= t('确认归档选中的会话吗？') %>"><%= t('归档') %></button>
        <button class="inline-btn" type="submit" name="action" value="restore" data-bulk-action data-confirm-message="<%= t('确认恢复选中的会话吗？') %>"><%= t('恢复') %></button>
        <button class="inline-btn is-danger" type="submit" name="action" value="delete" data-bulk-action data-confirm-message="<%= t('确认删除选中的会话吗？删除后会进入已删除状态。') %>"><%= t('删除') %></button>
      </div>
    </div>

    <% if (conversationList.length === 0) { %>
      <div class="empty-panel dashboard-empty-state">
        没有找到符合条件的会话。
        <div class="dashboard-empty-actions">
          <a class="quick-link" href="/conversations"><%= t('查看进行中的会话') %></a>
          <a class="quick-link" href="/characters/public"><%= t('去开始新对话') %></a>
        </div>
      </div>
    <% } else { %>
      <div class="conversation-manager-list">
        <% conversationList.forEach((conversation) => { %>
          <article class="conversation-manager-card">
            <label class="conversation-card-check" aria-label="选择会话 <%= conversation.title || conversation.id %>">
              <input type="checkbox" name="conversationIds" value="<%= conversation.id %>" data-conversation-checkbox />
            </label>
            <div class="conversation-card-body">
              <div class="admin-conversation-summary conversation-card-summary">
                <div>
                  <div class="dashboard-item-meta conversation-card-meta">
                    <span class="meta-chip"><%= statusLabels[conversation.status] || conversation.status %></span>
                    <span class="meta-chip"><%= t('消息') %> <strong><%= conversation.message_count || 0 %></strong></span>
                    <span class="meta-chip"><%= conversation.selected_model_mode || 'default' %></span>
                  </div>
                  <h3><%= conversation.title || '未命名对话' %></h3>
                  <p><%= conversation.character_name %></p>
                </div>
                <div class="toolbar-row toolbar-row--admin conversation-card-actions">
                  <button class="inline-btn conversation-more-trigger" type="button" data-conversation-actions-trigger aria-label="<%= t('会话操作') %>"><span aria-hidden="true">⋯</span></button>
                  <template data-conversation-actions-template data-conversation-id="<%= conversation.id %>">
                    <div class="conversation-actions-card" data-conversation-actions-card>
                      <div class="conversation-actions-head">
                        <span><%= t('操作') %></span>
                        <strong><%= conversation.title || t('未命名对话') %></strong>
                      </div>
                      <div class="conversation-actions-body">
                        <% if (conversation.status !== 'deleted') { %>
                          <a class="conversation-actions-item" href="/chat/<%= conversation.id %>"><%= t('进入对话') %></a>
                        <% } %>
                        <% if (conversation.status === 'active') { %>
                          <button class="conversation-actions-item" type="submit" form="conversationBulkForm" name="action" value="archive" data-single-conversation-action data-conversation-id="<%= conversation.id %>" data-confirm-message="<%= t('确认归档这条会话吗？') %>"><%= t('归档') %></button>
                        <% } %>
                        <% if (conversation.status === 'archived' || conversation.status === 'deleted') { %>
                          <button class="conversation-actions-item" type="submit" form="conversationBulkForm" name="action" value="restore" data-single-conversation-action data-conversation-id="<%= conversation.id %>" data-confirm-message="<%= t('确认恢复这条会话吗？') %>"><%= t('恢复') %></button>
                        <% } %>
                        <% if (conversation.status !== 'deleted') { %>
                          <button class="conversation-actions-item danger" type="submit" form="conversationBulkForm" name="action" value="delete" data-single-conversation-action data-conversation-id="<%= conversation.id %>" data-confirm-message="<%= t('确认删除这条会话吗？删除后会进入已删除状态。') %>"><%= t('删除') %></button>
                        <% } %>
                      </div>
                    </div>
                  </template>
                </div>
              </div>
              <% if (conversation.latest_message_preview) { %>
                <p class="admin-conversation-preview conversation-card-preview"><span><%= senderLabels[conversation.latest_sender_type] || conversation.latest_sender_type || '消息' %></span><%= conversation.latest_message_preview %></p>
              <% } else { %>
                <p class="admin-conversation-preview conversation-card-preview"><span><%= t('空') %></span><%= t('这条会话还没有可显示的消息。') %></p>
              <% } %>
              <div class="dashboard-item-meta">
                <span><%= t('创建：') %><%= conversation.display_created_at || conversation.created_at %></span>
                <span><%= t('更新：') %><%= conversation.display_updated_at || conversation.updated_at %></span>
                <span><%= t('角色 #') %><%= conversation.character_id %></span>
                <span><%= t('会话 #') %><%= conversation.id %></span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </form>

  <div class="toolbar-row toolbar-row--between conversation-pagination">
    <div class="admin-pagination">
      <% if (page > 1) { %>
        <a class="secondary-button" href="<%= buildPageUrl(1) %>"><%= t('首页') %></a>
        <a class="secondary-button" href="<%= buildPageUrl(page - 1) %>"><%= t('上一页') %></a>
      <% } %>
      <span class="meta-chip"><strong><%= page %></strong> / <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a class="secondary-button" href="<%= buildPageUrl(page + 1) %>"><%= t('下一页') %></a>
        <a class="secondary-button" href="<%= buildPageUrl(totalPages) %>"><%= t('末页') %></a>
      <% } %>
    </div>
  </div>
</section>
