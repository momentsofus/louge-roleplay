    { key: 'models', href: '/admin/models', label: t('预设模型') },
    { key: 'plans', href: '/admin/plans', label: t('套餐配置') },
    { key: 'prompts', href: '/admin/prompts', label: t('Prompt 配置') },
    { key: 'notifications', href: '/admin/notifications', label: t('通知中心') },
    { key: 'logs', href: '/admin/logs', label: t('日志查询') },
    { key: 'characters', href: '/admin/characters', label: t('角色卡管理') },
    { key: 'conversations', href: '/admin/conversations', label: t('对话记录') },
  ];
%>
<div class="admin-subnav">
  <% navItems.forEach(item => { %>
    <a class="quick-link <%= activeAdminNav === item.key ? 'is-active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
  <% }) %>
</div>
