<%# @file src/views/partials/admin-subnav.ejs
    @description 后台二级导航。依赖 navigation.adminNavItems 与 activeAdminNav，新增后台页面时同步 nav key。
%>
<%
  const navItems = (typeof navigation !== 'undefined' && navigation.adminNavItems) || [];
%>
<div class="admin-subnav">
  <% navItems.forEach(item => { %>
    <a class="quick-link <%= activeAdminNav === item.key ? 'is-active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
  <% }) %>
</div>
