<!-- @file src/views/partials/chat-message.ejs
     @description 单条聊天消息局部模板。调用说明：聊天页首屏和 /messages/history、流式 done 包都会用它渲染消息 HTML。
-->
<article class="bubble bubble-<%= message.sender_type === 'system' ? 'system' : message.sender_type %>" data-message-id="<%= message.id %>">
  <div class="bubble-header">
    <span class="bubble-role">
      <%= message.sender_type === 'user' ? '你' : (message.sender_type === 'character' ? conversation.character_name : '系统') %>
    </span>
    <span class="bubble-kind">#<%= message.id %> · <%= message.prompt_kind || 'normal' %></span>
  </div>

  <div class="bubble-rich" data-message-content><div class="bubble-text"><%= message.content %></div></div>

  <div class="message-tools">
    <div class="bubble-actions bubble-actions--stacked">
      <form method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/replay" class="inline-form" data-stream-endpoint="/chat/<%= conversation.id %>/messages/<%= message.id %>/replay/stream" data-stream-mode="replay" data-stream-role-label="<%= conversation.character_name %>" data-stream-kind-label="重算中…" data-stream-sender-class="character" data-stream-preview-content="<%= (message.sender_type === 'user' ? message.content : ((message.parent_preview_user_content || message.parentUserPreviewContent || '') || '')) %>">
        <button class="inline-btn" type="submit">从这里重算后续</button>
      </form>

      <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/delete" onsubmit="return confirm('确认删除这条对话记录吗？现在只允许删除没有后续消息、也没有独立分支会话引用的末端记录。');">
        <button class="inline-btn danger" type="submit">删除这条记录</button>
      </form>

      <% if (message.sender_type === 'character') { %>
        <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/regenerate/<%= message.id %>" data-stream-endpoint="/chat/<%= conversation.id %>/regenerate/<%= message.id %>/stream" data-stream-mode="regenerate" data-stream-role-label="<%= conversation.character_name %>" data-stream-kind-label="重新生成中…" data-stream-sender-class="character">
          <button class="inline-btn" type="submit">重新生成候选</button>
        </form>
      <% } %>
    </div>

    <% if (message.sender_type === 'character') { %>
      <details class="tool-details">
        <summary>改写这条 AI 回复</summary>
        <div class="tool-details-body">
          <form class="editor-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/edit">
            <textarea name="content" maxlength="8000" required><%= message.visibleContent %></textarea>
            <button class="inline-btn primary" type="submit">保存为新版本</button>
          </form>
          <div class="mini-note">这里只放可见正文，不带 think 思考内容；保存后会作为新的候选版本。</div>
        </div>
      </details>
    <% } %>

    <% if (message.sender_type === 'user') { %>
      <details class="tool-details">
        <summary>修改这句用户输入并重算</summary>
        <div class="tool-details-body">
          <form class="editor-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/edit-user">
            <textarea name="content" maxlength="4000" required><%= message.content %></textarea>
            <button class="inline-btn primary" type="submit">修改这句并重新生成</button>
          </form>
          <div class="mini-note">会保留旧记录并生成一条新后续，但不再展示复杂分支导航。</div>
        </div>
      </details>
    <% } %>
  </div>
</article>
