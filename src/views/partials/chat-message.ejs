<!-- @file src/views/partials/chat-message.ejs
     @description 单条聊天消息局部模板。调用说明：聊天页首屏和 /messages/history、流式 done 包都会用它渲染消息 HTML。
-->
<article class="bubble bubble-<%= message.sender_type === 'system' ? 'system' : message.sender_type %>" data-message-id="<%= message.id %>">
  <div class="bubble-header">
    <span class="bubble-role">
      <%= message.sender_type === 'user' ? t('你') : (message.sender_type === 'character' ? conversation.character_name : t('系统')) %>
    </span>
    <% if (message.status === 'streaming') { %>
      <span class="bubble-status"><%= t('生成中断，已保留这段回复。') %></span>
    <% } %>
    <details class="message-menu">
      <summary aria-label="<%= t('消息操作') %>">⋯</summary>
      <div class="message-menu-body">
        <% if (message.sender_type === 'character') { %>
          <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/regenerate/<%= message.id %>" data-stream-endpoint="/chat/<%= conversation.id %>/regenerate/<%= message.id %>/stream" data-stream-mode="regenerate" data-stream-role-label="<%= conversation.character_name %>" data-stream-kind-label="<%= t('重新生成中…') %>" data-stream-sender-class="character">
            <button class="message-menu-item" type="submit"><%= t('重新生成') %></button>
          </form>
          <details class="message-menu-details">
            <summary class="message-menu-item"><%= t('修改回复') %></summary>
            <div class="message-menu-editor">
              <form class="editor-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/edit">
                <textarea name="content" maxlength="8000" required><%= message.visibleContent || message.content %></textarea>
                <button class="inline-btn primary" type="submit"><%= t('保存修改') %></button>
              </form>
              <p class="mini-note"><%= t('保存后会回到当前对话，并显示修改后的内容。') %></p>
            </div>
          </details>
        <% } %>

        <% if (message.sender_type === 'user') { %>
          <details class="message-menu-details">
            <summary class="message-menu-item"><%= t('修改并重发') %></summary>
            <div class="message-menu-editor">
              <form class="editor-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/edit-user">
                <textarea name="content" maxlength="4000" required><%= message.content %></textarea>
                <button class="inline-btn primary" type="submit"><%= t('重新生成回复') %></button>
              </form>
              <p class="mini-note"><%= t('会用修改后的内容继续生成，并显示新的回复。') %></p>
            </div>
          </details>
        <% } %>

        <% if (message.sender_type !== 'system' && message.hasVisibleContinuation) { %>
          <form method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/replay" class="inline-form" data-stream-endpoint="/chat/<%= conversation.id %>/messages/<%= message.id %>/replay/stream" data-stream-mode="replay" data-stream-role-label="<%= conversation.character_name %>" data-stream-kind-label="<%= t('重写中…') %>" data-stream-sender-class="character" data-stream-preview-content="<%= (message.sender_type === 'user' ? message.content : ((message.parent_preview_user_content || message.parentUserPreviewContent || '') || '')) %>">
            <button class="message-menu-item" type="submit"><%= t('从这里重写') %></button>
          </form>
        <% } %>

        <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/delete" onsubmit="return confirm('<%= t('确认删除这条消息吗？只能删除最后一条没有后续关联的消息。') %>');">
          <button class="message-menu-item danger" type="submit"><%= t('删除消息') %></button>
        </form>
      </div>
    </details>
  </div>

  <div class="bubble-rich" data-message-content><div class="bubble-text"><%= message.visibleContent || message.content %></div></div>
</article>
