<%# @file src/views/partials/admin-hero.ejs
    @description 后台页面统一 hero 区块。locals: kicker/title/description/actions/extraClass/rightHtml。
    @notes rightHtml 由后台模板传入已可信片段；不要把用户输入未经转义后拼进 rightHtml。
%>
<%
  const heroActions = typeof actions !== 'undefined' && Array.isArray(actions) ? actions : [];
  const heroExtraClass = typeof extraClass !== 'undefined' ? extraClass : '';
  const heroRightHtml = typeof rightHtml !== 'undefined' ? rightHtml : '';
%>
<section class="hero-card admin-hero <%= heroExtraClass %>">
  <div class="admin-hero-copy">
    <% if (kicker) { %><p class="section-kicker"><%= kicker %></p><% } %>
    <h1><%= title %></h1>
    <% if (description) { %><p class="muted-text"><%= description %></p><% } %>
    <% if (heroActions.length) { %>
      <div class="toolbar-row toolbar-row--admin">
        <% heroActions.forEach(action => { %>
          <a class="<%= action.className || 'quick-link' %>" href="<%= action.href %>"><%= action.label %></a>
        <% }) %>
      </div>
    <% } %>
  </div>
  <% if (heroRightHtml) { %>
    <%- heroRightHtml %>
  <% } %>
</section>
