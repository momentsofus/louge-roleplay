<!-- @file src/views/chat.ejs
     @description 聊天主页面模板。调用说明：GET /chat/:conversationId 渲染，public/js/chat-page.js 接管流式发送、历史加载和富文本渲染。
-->
<link rel="stylesheet" href="/public/styles/site-pages.css" />
<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="chat-error-banner">
    <%= errorMessage %>
  </div>
<% } %>
<div class="chat-shell">
  <div class="chat-main">
    <section class="chat-head">
      <h1><%= conversation.character_name %></h1>
      <p><%= conversation.character_summary %></p>
      <div class="chat-head-actions">
        <form method="POST" action="/chat/<%= conversation.id %>/delete" onsubmit="return confirm('确认删除这条对话吗？只有没有子分支会话的末端对话才能删除。');">
          <button class="inline-btn danger" type="submit">删除这条对话</button>
        </form>
      </div>
      <% if (conversation.composed_system_prompt) { %>
        <div class="chat-meta chat-meta--spaced">
          <span class="meta-pill">后台控制模型</span>
          <span class="meta-pill">已启用提示词拼接</span>
        </div>
      <% } %>
      <div class="chat-meta">
        <span class="meta-pill">对话 #<%= conversation.id %></span>
        <span class="meta-pill" data-active-leaf-label>当前叶子 #<%= view.activeLeafId || '—' %></span>
        <span class="meta-pill">消息 <%= view.messageCount %> 条</span>
        <% if (view.currentBranch && view.currentBranch.label) { %>
          <span class="meta-pill"><%= view.currentBranch.label %></span>
        <% } %>
        <% if (conversation.parent_conversation_id) { %>
          <span class="meta-pill">分支自对话 #<%= conversation.parent_conversation_id %></span>
        <% } %>
      </div>
    </section>

    <section class="panel">
      <h2 class="panel-title">当前分支</h2>
      <p class="section-subtitle">先把这一条线顺着读完。分支、重算、改写都收在每条消息下面，不抢正文。</p>
      <% if (view.hasOlderMessages) { %>
        <div class="history-loader" data-history-loader>
          <button class="inline-btn" type="button" data-load-older-messages data-endpoint="/chat/<%= conversation.id %>/messages/history" data-before-id="<%= view.oldestVisibleMessageId || '' %>">加载之前的对话</button>
          <span class="mini-note">默认只显示最新 3 条，之前的内容按需加载。</span>
        </div>
      <% } %>
      <div class="conversation-path" data-visible-count="<%= view.visiblePathMessages.length %>" data-total-count="<%= view.pathMessages.length %>" data-oldest-visible-id="<%= view.oldestVisibleMessageId || '' %>">
        <% view.visiblePathMessages.forEach(message => { %>
          <%- include('partials/chat-message', { conversation, message }) %>
        <% }) %>
      </div>
    </section>

    <section class="compose-card">
      <h2>继续写这一支</h2>
      <p class="section-subtitle">高频动作只留发送，模型切换和输入优化收起来，别把页面挤成控制台。</p>
      <% if (chatModelSelector && chatModelSelector.options && chatModelSelector.options.length) { %>
        <details class="compose-details">
          <summary>模型模式</summary>
          <div class="compose-details-body">
            <div class="mini-note">你可以自由切换 1-3 模式。这里只显示模式名称，不显示真实模型 ID。当前 Provider 上下文上限 <%= chatModelSelector.maxContextTokens %>，超出后会裁到 <%= chatModelSelector.trimContextTokens %> 并自动用第 4 模型压缩历史。</div>
            <form method="POST" action="/chat/<%= conversation.id %>/model">
              <div class="mode-option-list">
                <% chatModelSelector.options.forEach((option, index) => { %>
                  <label class="mode-option <%= (conversation.selected_model_mode || 'standard') === option.mode ? 'active' : '' %>">
                    <input type="radio" name="modelMode" value="<%= option.mode %>" <%= (conversation.selected_model_mode || 'standard') === option.mode ? 'checked' : '' %> />
                    <div>
                      <div><strong><%= index + 1 %>. <%= option.label %></strong></div>
                      <div class="mini-note">已绑定可用模型，前台不展示具体 model ID。</div>
                    </div>
                  </label>
                <% }) %>
              </div>
              <button class="inline-btn primary" type="submit">切换模型模式</button>
            </form>
          </div>
        </details>
      <% } %>

      <form method="POST" action="/chat/<%= conversation.id %>/message" id="chat-compose-form" data-conversation-id="<%= conversation.id %>" data-character-name="<%= conversation.character_name %>" data-stream-endpoint="/chat/<%= conversation.id %>/message/stream" data-optimize-stream-endpoint="/chat/<%= conversation.id %>/optimize-input/stream" data-message-count="<%= view.messageCount %>">
        <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
        <label for="content">从当前节点往下写</label>
        <textarea id="content" name="content" maxlength="4000" placeholder="<%= view.messageCount === 0 ? '第一次可以直接点发送开始对话；也可以先输入你想说的话。' : '把你现在想说的话发出去。' %>"><%= draftContent || '' %></textarea>
        <button class="submit-btn" type="submit"><%= view.messageCount === 0 ? '开始 / 发送' : '发送消息' %></button>
      </form>

      <details class="compose-details">
        <summary>优化输入</summary>
        <div class="compose-details-body">
          <form method="POST" action="/chat/<%= conversation.id %>/optimize-input" class="editor-form" id="chat-optimize-form">
            <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
            <label for="optimizeContent">先优化输入</label>
            <textarea id="optimizeContent" name="content" maxlength="4000" required placeholder="想润色一下，就把原话贴这儿。"><%= draftContent || '' %></textarea>
            <button class="submit-btn" type="submit">优化输入</button>
          </form>

          <% if (optimizedContent) { %>
            <div class="draft-box">
              <label>优化结果</label>
              <div class="rich-preview" data-message-content><div class="bubble-text"><%= optimizedContent %></div></div>
              <div class="bubble-actions bubble-actions--solid">
                <form class="inline-form" method="GET" action="/chat/<%= conversation.id %>">
                  <input type="hidden" name="leaf" value="<%= view.activeLeafId || '' %>" />
                  <input type="hidden" name="draft" value="<%= optimizedContent %>" />
                  <button class="inline-btn" type="submit">带回输入框</button>
                </form>
                <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/message">
                  <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
                  <input type="hidden" name="content" value="<%= optimizedContent %>" />
                  <button class="inline-btn primary" type="submit">一键采用并发送</button>
                </form>
              </div>
            </div>
          <% } %>
        </div>
      </details>

      <% if (regeneratedPreview && regeneratedPreview.length) { %>
        <div class="draft-box">
          <label>本次重算生成的新片段</label>
          <div class="rich-preview">
            <% regeneratedPreview.forEach(item => { %>
              <div>
                <strong><%= item.role %>：</strong>
                <div data-message-content><div class="bubble-text"><%= item.content %></div></div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </section>
  </div>
  <aside class="chat-side">
    <section class="sidebar-card compact">
      <h2>分支导航</h2>
      <p class="mini-note">右边只保留导航用途：先看当前路径，再决定要不要切树、切叶子。</p>
    </section>

    <section class="sidebar-card">
      <h2>对话树</h2>
      <p class="mini-note">高亮的是你当前这条线，树节点支持两行摘要，切换时不用盯着一排编号猜内容。</p>
      <div class="tree-list">
        <% view.treeEntries.forEach(node => { %>
          <div class="tree-node <%= node.isActive ? 'active' : '' %> <%= node.isOnActiveTrail ? 'trail' : '' %>" style="margin-left: <%= node.depth * 16 %>px;">
            <span class="tree-line"></span>
            <span class="tree-id">#<%= node.id %></span>
            <span class="tree-kind"><%= node.senderType === 'user' ? '你' : 'AI' %></span>
            <span class="tree-content"><%= node.shortContent || '（空）' %></span>
            <form class="inline-form" method="GET" action="/chat/<%= conversation.id %>">
              <input type="hidden" name="leaf" value="<%= node.id %>" />
              <button class="inline-btn <%= node.isActive ? 'primary' : '' %>" type="submit"><%= node.isActive ? '当前' : '切换' %></button>
            </form>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="sidebar-card">
      <h2>叶子分支</h2>
      <p class="mini-note">这里只保留“切到哪一支”的信息，避免把主阅读区打散。</p>
      <% view.branches.forEach(branch => { %>
        <div class="branch-item <%= branch.isActive ? 'active' : '' %>">
          <div class="branch-meta">叶子 #<%= branch.leafId %> · 深度 <%= branch.depth %> · <%= branch.promptKind %></div>
          <div class="branch-preview"><strong><%= branch.label %></strong></div>
          <div class="mini-note"><%= branch.summary %></div>
          <form class="inline-form" method="GET" action="/chat/<%= conversation.id %>">
            <input type="hidden" name="leaf" value="<%= branch.leafId %>" />
            <button class="inline-btn <%= branch.isActive ? 'primary' : '' %>" type="submit">
              <%= branch.isActive ? '当前分支' : '切换到这支' %>
            </button>
          </form>
        </div>
      <% }) %>
    </section>

    <details class="sidebar-details">
      <summary>使用方式</summary>
      <div class="sidebar-details-body mini-note">
        <div>1. 第一次进入空白对话时，可以直接点发送，系统会自动用“[开始一次新的对话]”起头一次。</div>
        <div>2. 重新生成：给同一条用户输入再生一个 AI 候选。</div>
        <div>3. 保存为新 AI 分支：手动改写 AI 回复，但不覆盖旧版本。</div>
        <div>4. 修改用户输入并重开分支：从旧用户节点重新长出一条新线。</div>
        <div>5. 从这里重算后续：保持前文不变，从当前节点重开新的后续走向。</div>
        <div>6. 新建独立分支对话：把当前节点之前的主线复制成一个新会话。</div>
        <div>7. 优化输入：先润色，再一键采用并发送。</div>
      </div>
    </details>
  </aside>
</div>
<script src="/public/js/chat-page.js?v=stream-timeout-idle-v2"></script>
