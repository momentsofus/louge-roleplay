<style>
  .chat-shell {
    display: grid;
    gap: 20px;
  }

  .chat-head {
    padding: 28px;
    border-radius: 28px;
    background: linear-gradient(180deg, #141413 0%, #30302e 100%);
    color: #faf9f5;
    border: 1px solid #30302e;
    box-shadow: rgba(20, 20, 19, 0.12) 0px 24px 60px;
  }

  .chat-head h1 {
    font-size: 42px;
    color: #faf9f5;
    margin-bottom: 10px;
  }

  .chat-head p {
    margin: 0;
    color: #d8d4ca;
    line-height: 1.75;
  }

  .chat-meta {
    margin-top: 10px;
    font-size: 14px;
    color: #d8d4ca;
  }

  .chat-log,
  .chat-compose {
    background: #faf9f5;
    border: 1px solid #f0eee6;
    border-radius: 24px;
    padding: 22px;
    box-shadow: rgba(20, 20, 19, 0.05) 0px 8px 24px;
  }

  .bubble {
    padding: 16px 18px;
    border-radius: 20px;
    margin-bottom: 14px;
    white-space: pre-wrap;
    line-height: 1.75;
    position: relative;
  }

  .bubble-user {
    background: #efe2da;
    color: #4d3f39;
    border: 1px solid #ead3c7;
  }

  .bubble-character {
    background: #f3f0e8;
    color: #2f2e2b;
    border: 1px solid #e8e6dc;
  }

  .bubble-inactive {
    opacity: 0.48;
  }

  .bubble strong {
    display: block;
    margin-bottom: 6px;
  }

  .bubble small {
    display: inline-block;
    margin-top: 10px;
    color: #7b766f;
  }

  .bubble-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .inline-form {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
  }

  .inline-form input,
  .inline-form textarea,
  .inline-form button {
    width: auto;
  }

  .inline-form textarea {
    width: min(100%, 540px);
    min-height: 96px;
    resize: vertical;
  }

  .inline-btn {
    padding: 8px 12px;
    border-radius: 12px;
    background: #f3ede4;
    color: #403d39;
    border: 1px solid #e5ddd2;
    box-shadow: none;
  }

  .inline-btn.primary {
    background: #c96442;
    border-color: #c96442;
    color: #faf9f5;
  }

  .submit-btn {
    margin-top: 14px;
    background: #c96442;
    border-color: #c96442;
    box-shadow: 0px 0px 0px 1px #c96442;
    color: #faf9f5;
  }

  .submit-btn:hover,
  .inline-btn.primary:hover {
    background: #d97757;
  }

  .opt-box {
    margin-top: 16px;
    padding: 16px;
    border-radius: 18px;
    background: #f3f0e8;
    border: 1px solid #e8e6dc;
  }

  .branch-list {
    margin-top: 8px;
    color: #6b665f;
    font-size: 14px;
  }
</style>

<div class="chat-shell">
  <section class="chat-head">
    <h1><%= conversation.character_name %></h1>
    <p><%= conversation.character_summary %></p>
    <div class="chat-meta">
      当前对话 ID：<%= conversation.id %>
      <% if (conversation.parent_conversation_id) { %>
        · 来自分支对话 <%= conversation.parent_conversation_id %>
      <% } %>
      <% if (activeLeafId) { %>
        · 当前叶子消息：<%= activeLeafId %>
      <% } %>
    </div>
  </section>

  <section class="chat-log">
    <% decoratedMessages.forEach(message => { %>
      <div class="bubble <%= message.sender_type === 'user' ? 'bubble-user' : 'bubble-character' %> <%= message.is_active ? '' : 'bubble-inactive' %>">
        <strong><%= message.sender_type === 'user' ? '你' : conversation.character_name %></strong>
        <div><%= message.content %></div>
        <small>
          #<%= message.id %>
          · <%= message.prompt_kind || 'normal' %>
          <% if (!message.is_active) { %> · 非当前分支 <% } %>
        </small>

        <% if (message.child_count > 0) { %>
          <div class="branch-list">子节点：<%= message.child_leaf_ids.join(', ') %></div>
        <% } %>

        <div class="bubble-actions">
          <form class="inline-form" method="GET" action="/chat/<%= conversation.id %>">
            <input type="hidden" name="leaf" value="<%= message.id %>" />
            <button class="inline-btn" type="submit">切到这里</button>
          </form>

          <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/branch/<%= message.id %>">
            <button class="inline-btn" type="submit">从这里开分支</button>
          </form>

          <% if (message.sender_type === 'character') { %>
            <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/regenerate/<%= message.id %>">
              <button class="inline-btn" type="submit">重新生成</button>
            </form>
          <% } %>
        </div>

        <% if (message.sender_type === 'character') { %>
          <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/messages/<%= message.id %>/edit">
            <textarea name="content" maxlength="8000" required><%= message.content %></textarea>
            <button class="inline-btn primary" type="submit">保存 AI 内容</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </section>

  <section class="chat-compose">
    <form method="POST" action="/chat/<%= conversation.id %>/message">
      <input type="hidden" name="parentMessageId" value="<%= activeLeafId || '' %>" />
      <label for="content">继续说点什么</label>
      <textarea id="content" name="content" maxlength="4000" required placeholder="把你现在想说的话发出去。"><%= draftContent || '' %></textarea>
      <button class="submit-btn" type="submit">发送消息</button>
    </form>

    <div class="opt-box">
      <form method="POST" action="/chat/<%= conversation.id %>/optimize-input">
        <input type="hidden" name="parentMessageId" value="<%= activeLeafId || '' %>" />
        <label for="optimizeContent">先帮我优化输入</label>
        <textarea id="optimizeContent" name="content" maxlength="4000" required placeholder="想润色一下，就把原话贴这儿。"><%= draftContent || '' %></textarea>
        <button class="submit-btn" type="submit">优化输入</button>
      </form>

      <% if (optimizedContent) { %>
        <div class="opt-box">
          <label>优化结果</label>
          <div style="white-space: pre-wrap;"><%= optimizedContent %></div>
          <form method="GET" action="/chat/<%= conversation.id %>" style="margin-top: 12px;">
            <input type="hidden" name="leaf" value="<%= activeLeafId || '' %>" />
            <input type="hidden" name="draft" value="<%= optimizedContent %>" />
            <button class="inline-btn primary" type="submit">带回输入框继续发</button>
          </form>
        </div>
      <% } %>
    </div>
  </section>
</div>
