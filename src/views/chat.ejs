<!-- @file src/views/chat.ejs
     @description 聊天主页面模板。调用说明：GET /chat/:conversationId 渲染，public/js/chat/controller.js 接管流式发送、历史加载和富文本渲染。
-->
<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="chat-error-banner">
    <%= errorMessage %>
  </div>
<% } %>
<% const safeChatBackground = typeof escapeHtml === 'function' ? escapeHtml(conversation.background_image_path || '') : String(conversation.background_image_path || '').replace(/'/g, '%27'); %>
<div class="chat-shell chat-shell--linear <%= conversation.background_image_path ? 'chat-shell--with-bg' : '' %>" <% if (conversation.background_image_path) { %>style="--chat-bg-image: url('<%- safeChatBackground %>');"<% } %>>
  <div class="chat-main">
    <section class="chat-head chat-head--clean">
      <% if (conversation.avatar_image_path) { %>
        <div class="chat-head-avatar chat-head-avatar--image"><img src="<%= conversation.avatar_image_path %>" alt="<%= conversation.character_name %>" decoding="async" /></div>
      <% } %>
      <div>
        <p class="eyebrow"><%= t('正在和') %></p>
        <h1><%= conversation.character_name %></h1>
        <p><%= conversation.character_summary %></p>
      </div>
      <div class="chat-head-actions">
        <details class="more-menu chat-more-menu">
          <summary class="inline-btn"><%= t('更多') %></summary>
          <div class="more-menu-body">
            <form method="POST" action="/chat/<%= conversation.id %>/delete" data-confirm-message="<%= t('确认删除这条对话吗？只有没有后续关联的对话才能删除。') %>">
              <button class="inline-btn danger" type="submit"><%= t('删除这条对话') %></button>
            </form>
            <p class="mini-note"><%= t('删除只适用于没有后续关联的对话，避免误删已有内容。') %></p>
          </div>
        </details>
      </div>
    </section>

    <section class="panel chat-transcript-panel">
      <% if (view.hasOlderMessages) { %>
        <div class="history-loader" data-history-loader>
          <button class="inline-btn" type="button" data-load-older-messages data-endpoint="/chat/<%= conversation.id %>/messages/history" data-before-id="<%= view.oldestVisibleMessageId || '' %>"><%= t('查看更早的消息') %></button>
          <span class="mini-note"><%= t('为了打开更快，较早内容会在需要时加载。') %></span>
        </div>
      <% } %>
      <div class="chat-transcript" data-visible-count="<%= view.visiblePathMessages.length %>" data-total-count="<%= view.pathMessages.length %>" data-oldest-visible-id="<%= view.oldestVisibleMessageId || '' %>" data-keep-latest="<%= view.initialVisibleCount || 8 %>">
        <% if (!view.visiblePathMessages.length) { %>
          <div class="empty-chat-state">
            <h2><%= t('开始和 {name} 对话', { name: conversation.character_name }) %></h2>
            <p><%= t('直接输入消息，或发送空白开场请求让角色先发出开场白。') %></p>
          </div>
        <% } %>
        <% view.visiblePathMessages.forEach(message => { %>
          <%- include('partials/chat-message', { conversation, message }) %>
        <% }) %>
      </div>
    </section>

    <section class="compose-card compose-card--linear">
      <form method="POST" action="/chat/<%= conversation.id %>/message" id="chat-compose-form" data-conversation-id="<%= conversation.id %>" data-character-name="<%= conversation.character_name %>" data-stream-endpoint="/chat/<%= conversation.id %>/message/stream" data-optimize-stream-endpoint="/chat/<%= conversation.id %>/optimize-input/stream" data-message-count="<%= view.messageCount %>">
        <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
        <label class="sr-only" for="content"><%= t('输入消息') %></label>
        <textarea id="content" name="content" maxlength="4000" placeholder="<%= t(view.messageCount === 0 ? '第一次可以直接点发送开始对话；也可以先输入你想说的话。' : '输入你想说的话…') %>"><%= draftContent || '' %></textarea>
        <div class="compose-actions compose-actions--linear">
          <span class="mini-note"><%= t('PC 端 Enter 发送，Shift+Enter 换行；移动端回车只换行。') %></span>
          <button class="submit-btn" type="submit"><%= t(view.messageCount === 0 ? '开始 / 发送' : '发送') %></button>
        </div>
      </form>

      <details class="compose-details compose-details--compact">
        <summary><%= t('优化输入') %></summary>
        <div class="compose-details-body">
          <form method="POST" action="/chat/<%= conversation.id %>/optimize-input" class="editor-form" id="chat-optimize-form">
            <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
            <label for="optimizeContent"><%= t('优化这条输入') %></label>
            <textarea id="optimizeContent" name="content" maxlength="4000" required placeholder="<%= t('输入需要优化的消息内容。') %>"><%= draftContent || '' %></textarea>
            <button class="inline-btn primary" type="submit"><%= t('优化输入') %></button>
          </form>
        </div>
      </details>

      <% if (optimizedContent) { %>
        <div class="draft-box">
          <label><%= t('润色结果') %></label>
          <div class="rich-preview" data-message-content><div class="bubble-text"><%= optimizedContent %></div></div>
          <div class="bubble-actions bubble-actions--solid">
            <form class="inline-form" method="GET" action="/chat/<%= conversation.id %>">
              <input type="hidden" name="leaf" value="<%= view.activeLeafId || '' %>" />
              <input type="hidden" name="draft" value="<%= optimizedContent %>" />
              <button class="inline-btn" type="submit"><%= t('放回输入框') %></button>
            </form>
            <form class="inline-form" method="POST" action="/chat/<%= conversation.id %>/message">
              <input type="hidden" name="parentMessageId" value="<%= view.activeLeafId || '' %>" />
              <input type="hidden" name="content" value="<%= optimizedContent %>" />
              <button class="inline-btn primary" type="submit"><%= t('使用并发送') %></button>
            </form>
          </div>
        </div>
      <% } %>

      <% if (newContinuationPreview && newContinuationPreview.length) { %>
        <div class="draft-box">
          <label><%= t('新的内容已生成') %></label>
          <div class="rich-preview">
            <% newContinuationPreview.forEach(item => { %>
              <div>
                <strong><%= item.role %>：</strong>
                <div data-message-content><div class="bubble-text"><%= item.content %></div></div>
              </div>
            <% }) %>
          </div>
          <p class="mini-note"><%= t('当前页面已切到新的内容。') %></p>
        </div>
      <% } %>
    </section>
  </div>

  <aside class="chat-side chat-side--assistant">
    <section class="sidebar-card character-card">
      <% if (conversation.avatar_image_path) { %>
        <div class="sidebar-character-avatar"><img src="<%= conversation.avatar_image_path %>" alt="<%= conversation.character_name %>" loading="lazy" decoding="async" /></div>
      <% } %>
      <p class="eyebrow"><%= t('角色') %></p>
      <h2><%= conversation.character_name %></h2>
      <p><%= conversation.character_summary %></p>
      <% if (conversation.composed_system_prompt) { %>
        <div class="chat-meta chat-meta--spaced">
          <span class="meta-pill"><%= t('已启用角色规则') %></span>
        </div>
      <% } %>
    </section>

    <% if (chatModelSelector && chatModelSelector.options && chatModelSelector.options.length) { %>
      <details class="sidebar-details">
        <summary><%= t('回应风格') %></summary>
        <div class="sidebar-details-body">
          <p class="mini-note"><%= t('选择不同回应风格。真实模型 ID 不会展示在前台。') %></p>
          <form method="POST" action="/chat/<%= conversation.id %>/model">
            <div class="mode-option-list">
              <% chatModelSelector.options.forEach((option, index) => { %>
                <label class="mode-option <%= (conversation.selected_model_mode || 'standard') === option.mode ? 'active' : '' %>">
                  <input type="radio" name="modelMode" value="<%= option.mode %>" <%= (conversation.selected_model_mode || 'standard') === option.mode ? 'checked' : '' %> />
                  <div>
                    <div><strong><%= index + 1 %>. <%= option.label %></strong></div>
                    <% if (option.description) { %><div class="mini-note"><%= option.description %></div><% } %>
                    <div class="mini-note">
                      <%= t('计费倍率') %>：<%= t('请求') %> ×<%= option.requestMultiplier %> · <%= t('文字额度') %> ×<%= option.tokenMultiplier %>
                    </div>
                  </div>
                </label>
              <% }) %>
            </div>
            <button class="inline-btn primary" type="submit"><%= t('保存回应风格') %></button>
          </form>
        </div>
      </details>
    <% } %>

    <section class="sidebar-card compact help-card">
      <h2><%= t('怎么用') %></h2>
      <ul>
        <li><%= t('想继续：直接输入并发送。') %></li>
        <li><%= t('不满意回复：点 AI 消息旁边的“重新生成”。') %></li>
        <li><%= t('刚才说错了：点你的消息旁边的“修改并重发”。') %></li>
        <li><%= t('需要改一段后续：在对应消息的“⋯”里选择“从这里重写”。') %></li>
      </ul>
    </section>
  </aside>
</div>
<script nonce="<%= cspNonce || '' %>" src="/public/js/generated/chat.bundle.js?v=v1.4.3-20260506" defer></script>
