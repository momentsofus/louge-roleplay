<!-- @file src/views/admin-logs.ejs
     @description 管理后台日志查询页面模板。调用说明：GET /admin/logs 由 web-routes.js 渲染，支持日期、等级、文件、错误类型、函数名与分页筛选。
-->
<div class="admin-shell">
  <section class="hero-card admin-hero">
    <div class="admin-hero-copy">
      <p class="section-kicker">Logs</p>
      <h1><%= t('日志查询') %></h1>
      <p class="muted-text"><%= t('这里放运行日志、错误日志和访问日志。按天拆文件后不再全塞一个大文件，想查哪天、哪类、哪个函数，直接筛。') %></p>
    </div>

    <div class="metrics metrics--compact">
      <div class="metric"><strong><%= logResult.total %></strong><span><%= t('匹配记录') %></span></div>
      <div class="metric"><strong><%= logResult.scannedFiles.length %></strong><span><%= t('扫描文件') %></span></div>
      <div class="metric"><strong><%= logResult.page %> / <%= logResult.totalPages %></strong><span><%= t('当前页') %></span></div>
    </div>
  </section>

  <section class="section-card admin-section">
    <%- include('partials/admin-subnav', { activeAdminNav: 'logs' }) %>

    <div class="section-heading">
      <div>
        <p class="section-kicker">Filters</p>
        <h2><%= t('筛选条件') %></h2>
        <p class="muted-text"><%= t('等级、文件报错、类型报错、函数报错、日期都在这。留空就是不过滤。') %></p>
      </div>
    </div>

    <form class="admin-log-filter" method="get" action="/admin/logs">
      <label>
        <%= t('日期') %>
        <input type="date" name="date" value="<%= logResult.filters.date %>" />
      </label>
      <label>
        <%= t('等级') %>
        <select name="level">
          <option value=""><%= t('全部等级') %></option>
          <% logResult.levels.forEach(level => { %>
            <option value="<%= level %>" <%= logResult.filters.level === level ? 'selected' : '' %>><%= level %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t('文件报错') %>
        <input list="log-source-files" type="search" name="file" value="<%= logResult.filters.file %>" placeholder="<%= t('如 src/routes/web-routes.js') %>" />
      </label>
      <label>
        <%= t('类型报错') %>
        <input list="log-error-types" type="search" name="errorType" value="<%= logResult.filters.errorType %>" placeholder="<%= t('如 TypeError / SyntaxError') %>" />
      </label>
      <label>
        <%= t('函数报错') %>
        <input list="log-function-names" type="search" name="functionName" value="<%= logResult.filters.functionName %>" placeholder="<%= t('如 renderPage') %>" />
      </label>
      <label>
        <%= t('每页') %>
        <select name="pageSize">
          <% [25, 50, 100, 200].forEach(size => { %>
            <option value="<%= size %>" <%= Number(logResult.pageSize) === size ? 'selected' : '' %>><%= size %></option>
          <% }) %>
        </select>
      </label>
      <div class="toolbar-row toolbar-row--admin admin-log-filter-actions">
        <button type="submit"><%= t('查询日志') %></button>
        <a class="quick-link" href="/admin/logs"><%= t('清空筛选') %></a>
      </div>
    </form>

    <datalist id="log-source-files">
      <% logResult.sourceFiles.forEach(item => { %><option value="<%= item %>"></option><% }) %>
    </datalist>
    <datalist id="log-error-types">
      <% logResult.errorTypes.forEach(item => { %><option value="<%= item %>"></option><% }) %>
    </datalist>
    <datalist id="log-function-names">
      <% logResult.functionNames.forEach(item => { %><option value="<%= item %>"></option><% }) %>
    </datalist>

    <details class="admin-fold">
      <summary><%= t('扫描到的日志文件') %></summary>
      <div class="admin-fold-body">
        <div class="admin-log-file-list">
          <% logResult.scannedFiles.forEach(file => { %>
            <span class="meta-chip">
              <strong><%= file.name %></strong>
              <%= file.type %>
              · <%= Math.ceil(file.size / 1024) %> KB
              <%= file.truncated ? t('· 已按尾部截取') : '' %>
            </span>
          <% }) %>
          <% if (!logResult.scannedFiles.length) { %>
            <span class="muted-text"><%= t('还没有日志文件。') %></span>
          <% } %>
        </div>
      </div>
    </details>
  </section>

  <section class="section-card admin-section">
    <div class="toolbar-row toolbar-row--between">
      <div>
        <p class="section-kicker">Result</p>
        <h2><%= t('日志列表') %></h2>
      </div>
      <div class="admin-pagination">
        <% if (logResult.page > 1) { %>
          <a class="quick-link" href="<%= buildPageUrl(logResult.page - 1) %>"><%= t('上一页') %></a>
        <% } %>
        <span class="meta-chip"><strong><%= logResult.page %></strong> / <%= logResult.totalPages %></span>
        <% if (logResult.page < logResult.totalPages) { %>
          <a class="quick-link" href="<%= buildPageUrl(logResult.page + 1) %>"><%= t('下一页') %></a>
        <% } %>
      </div>
    </div>

    <% if (!logResult.entries.length) { %>
      <div class="empty-state">
        <strong><%= t('没查到日志') %></strong>
        <span class="muted-text"><%= t('换个日期或放宽筛选条件试试。') %></span>
      </div>
    <% } %>

    <div class="admin-log-list">
      <% logResult.entries.forEach(entry => { %>
        <details class="admin-item admin-log-entry" <%= entry.level === 'error' ? 'open' : '' %>>
          <summary>
            <div class="admin-item-main">
              <span class="pill pill--level pill--level-<%= entry.level %>"><%= entry.level %></span>
              <strong><%= entry.message %></strong>
              <% if (entry.errorType) { %><span class="pill"><%= entry.errorType %></span><% } %>
            </div>
            <div class="admin-item-meta">
              <span class="meta-chip"><%= entry.displayTime %></span>
              <span class="meta-chip"><%= entry.logFile %>:<%= entry.lineNumber %></span>
            </div>
          </summary>
          <div class="admin-item-body">
            <div class="admin-log-meta-grid">
              <span><strong><%= t('文件') %></strong><%= entry.sourceFile || entry.logFile %></span>
              <span><strong><%= t('函数') %></strong><%= entry.functionName || '—' %></span>
              <span><strong><%= t('类型') %></strong><%= entry.errorType || '—' %></span>
              <span><strong><%= t('位置') %></strong><%= entry.line ? `${entry.line}:${entry.column || 0}` : '—' %></span>
            </div>
            <% if (entry.metaText) { %>
              <pre class="admin-log-pre"><%= entry.metaText %></pre>
            <% } %>
            <pre class="admin-log-pre"><%= entry.raw %></pre>
          </div>
        </details>
      <% }) %>
    </div>
  </section>
</div>
