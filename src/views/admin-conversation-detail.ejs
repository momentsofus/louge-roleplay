<!-- @file src/views/admin-conversation-detail.ejs
     @description 管理后台单条对话详情页。调用说明：GET /admin/conversations/:conversationId 渲染完整消息链，可查看、恢复、永久删除软删除数据。
-->
<div class="admin-shell">
  <section class="hero-card admin-hero">
    <div class="admin-hero-copy">
      <p class="section-kicker">Conversation Detail</p>
      <h1><%= t('对话 #{id}', { id: detail.conversation.id }) %></h1>
      <p class="muted-text"><%= detail.conversation.title || t('未命名对话') %></p>
    </div>

    <div class="metrics metrics--compact">
      <div class="metric"><strong><%= detail.messages.length %></strong><span><%= t('消息总数') %></span></div>
      <div class="metric"><strong><%= detail.conversation.username %></strong><span><%= t('用户') %></span></div>
      <div class="metric"><strong><%= detail.conversation.character_name %></strong><span><%= t('角色卡') %></span></div>
    </div>
  </section>

  <section class="section-card admin-section">
    <%- include('partials/admin-subnav', { activeAdminNav: 'conversations' }) %>

    <div class="admin-log-meta-grid">
      <span><strong><%= t('用户') %></strong><%= detail.conversation.nickname ? `${detail.conversation.username}（${detail.conversation.nickname}）` : detail.conversation.username %></span>
      <span><strong><%= t('角色卡') %></strong><%= detail.conversation.character_name %> · <%= detail.conversation.character_visibility || 'public' %></span>
      <span><strong><%= t('创建时间') %></strong><%= detail.conversation.display_created_at %></span>
      <span><strong><%= t('更新时间') %></strong><%= detail.conversation.display_updated_at %></span>
      <span><strong><%= t('状态') %></strong><%= detail.conversation.status %></span>
      <span><strong><%= t('删除时间') %></strong><%= detail.conversation.display_deleted_at %></span>
    </div>

    <div class="toolbar-row toolbar-row--admin">
      <a class="quick-link" href="/admin/conversations"><%= t('返回对话列表') %></a>
      <% if (detail.conversation.status === 'deleted') { %>
        <form method="POST" action="/admin/conversations/<%= detail.conversation.id %>/restore">
          <button type="submit"><%= t('恢复会话') %></button>
        </form>
        <form method="POST" action="/admin/conversations/<%= detail.conversation.id %>/permanent-delete" data-confirm-message="<%= t('确认永久删除这条会话及其所有消息吗？这个操作不可恢复。') %>">
          <button type="submit" class="danger"><%= t('永久删除') %></button>
        </form>
      <% } %>
    </div>
  </section>

  <section class="section-card admin-section">
    <div>
      <p class="section-kicker">Messages</p>
      <h2><%= t('完整消息链') %></h2>
      <p class="muted-text"><%= t('按 sequence_no 顺序展示；已删除消息也会显示在这里，方便恢复和审计。') %></p>
    </div>

    <div class="admin-conversation-message-list">
      <% detail.messages.forEach(message => { %>
        <article id="message-<%= message.id %>" class="admin-conversation-message admin-conversation-message--<%= message.sender_type %>">
          <div class="toolbar-row toolbar-row--between">
            <div class="admin-item-main">
              <span class="pill pill--brand"><%= message.sender_type %></span>
              <strong>#<%= message.id %> · seq <%= message.sequence_no %></strong>
              <span class="pill"><%= message.prompt_kind || 'normal' %></span>
              <span class="pill"><%= message.status || 'success' %></span>
              <% if (message.deleted_at) { %><span class="pill">deleted</span><% } %>
            </div>
            <span class="meta-chip"><%= message.display_created_at %></span>
          </div>
          <div class="admin-conversation-message-links">
            <span>parent: <%= message.parent_message_id || '—' %></span>
            <span>branch: <%= message.branch_from_message_id || '—' %></span>
            <span>edited: <%= message.edited_from_message_id || '—' %></span>
            <span>deleted_at: <%= message.display_deleted_at %></span>
          </div>
          <pre class="admin-conversation-message-content"><%= message.content %></pre>
          <% if (message.deleted_at) { %>
            <div class="toolbar-row toolbar-row--admin">
              <form method="POST" action="/admin/conversations/<%= detail.conversation.id %>/messages/<%= message.id %>/restore">
                <button type="submit"><%= t('恢复消息') %></button>
              </form>
              <form method="POST" action="/admin/conversations/<%= detail.conversation.id %>/messages/<%= message.id %>/permanent-delete" data-confirm-message="<%= t('确认永久删除这条消息吗？这个操作不可恢复。') %>">
                <button type="submit" class="danger"><%= t('永久删除') %></button>
              </form>
            </div>
          <% } %>
        </article>
      <% }) %>
      <% if (!detail.messages.length) { %>
        <div class="empty-state">
          <strong><%= t('这条会话还没有消息') %></strong>
        </div>
      <% } %>
    </div>
  </section>
</div>
