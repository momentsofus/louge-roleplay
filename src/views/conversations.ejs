<!-- @file src/views/conversations.ejs
     @description 用户会话管理页。调用说明：GET /conversations 渲染，支持筛选、分页和批量操作。
-->
<%
  const result = conversationResult || {};
  const conversationList = Array.isArray(result.conversations) ? result.conversations : [];
  const currentFilters = filters || result.filters || {};
  const options = result.filterOptions || {};
  const characterOptions = Array.isArray(options.characters) ? options.characters : [];
  const stats = result.stats || {};
  const currentUrl = (typeof originalUrl !== 'undefined' && originalUrl) ? originalUrl : ((locals && locals.originalUrl) || '/conversations');
  const vm = (typeof viewModel !== 'undefined' ? viewModel : locals.viewModel) || {};
  const formatConversationCount = (value) => vm.formatNumber ? vm.formatNumber(value, locale || 'zh-CN') : Number(value || 0).toLocaleString('zh-CN');
  const statusLabels = { active: t('进行中'), archived: t('已归档'), deleted: t('已删除'), all: t('全部状态') };
  const senderLabels = { user: t('你'), character: t('角色'), system: t('系统') };
  const page = Number(result.page || 1);
  const totalPages = Number(result.totalPages || 1);
%>

<div class="dashboard-shell conversation-manager-shell">
  <%- include('partials/conversations/hero', {
    stats,
    result,
    formatConversationCount,
  }) %>

  <% if (notice) { %>
    <div class="panel conversation-manager-notice"><%= notice %></div>
  <% } %>

  <%- include('partials/conversations/filter-form', {
    currentFilters,
    characterOptions,
    result,
  }) %>

  <%- include('partials/conversations/list-panel', {
    currentUrl,
    conversationList,
    result,
    page,
    totalPages,
    statusLabels,
    senderLabels,
    buildPageUrl,
    formatConversationCount,
  }) %>
</div>

<script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/conversation-management.js') %>" defer></script>
