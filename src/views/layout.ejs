<!-- @file src/views/layout.ejs
     @description 全站布局模板。调用说明：renderPage 二次渲染时套用，注入导航、字体、客户端 i18n。
-->
<!DOCTYPE html>
<html lang="<%= locale || 'zh-CN' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <title><%= title %> - <%= appName %></title>
  <link rel="preconnect" href="/" />
  <link rel="stylesheet" href="/fonts/google.css?v=latin-v2" />
  <link rel="stylesheet" href="/public/styles/site-pages.css" />
  <script id="app-bootstrap-data" type="application/json" nonce="<%= cspNonce || '' %>"><%- JSON.stringify({
    i18n: { locale: locale || 'zh-CN', messages: clientI18nMessages || {} },
    notifications: { items: clientNotifications || [] },
    csrfToken: csrfToken || ''
  }) %></script>
  <script nonce="<%= cspNonce || '' %>" src="/public/js/layout-bootstrap.js"></script>
  <script nonce="<%= cspNonce || '' %>" src="/public/js/i18n-runtime.js"></script>
  <script nonce="<%= cspNonce || '' %>" src="/public/js/csrf.js"></script>
  <script nonce="<%= cspNonce || '' %>" src="/public/js/form-guards.js"></script>
  <script nonce="<%= cspNonce || '' %>" src="/public/js/notification-client.js" defer></script>
</head>
<body>
  <div class="container">
    <div class="nav">
      <a class="brand" href="/"><%= appName %></a>
      <span class="brand-url"><%= appUrl %></span>
      <a href="/"><%= t('首页') %></a>
      <% if (currentUser) { %>
        <a href="/dashboard"><%= t('控制台') %></a>
        <a href="/profile"><%= t('个人资料') %></a>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/admin"><%= t('管理后台') %></a>
      <% } %>
        <a href="/characters/new"><%= t('创建角色') %></a>
        <button type="button" class="nav-support-button" data-open-support><%= t('联系客服') %></button>
        <form method="POST" action="/logout" class="inline-form nav-logout-form"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" /><button type="submit" class="nav-link-button"><%= t('退出（{username}）', { username: currentUser.username }) %></button></form>
      <% } else { %>
        <a href="/login"><%= t('登录') %></a>
        <a href="/register"><%= t('注册') %></a>
        <button type="button" class="nav-support-button" data-open-support><%= t('联系客服') %></button>
      <% } %>
      <span class="nav-locale-switch">
        <span><%= t('语言') %>:</span>
        <a href="<%= localeSwitchLinks['zh-CN'] %>" class="<%= locale === 'zh-CN' ? 'active' : '' %>"><%= t('中文') %></a>
        <a href="<%= localeSwitchLinks.en %>" class="<%= locale === 'en' ? 'active' : '' %>"><%= t('English') %></a>
      </span>
    </div>
    <%- body %>
  </div>
</body>
</html>
