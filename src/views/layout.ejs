<!-- @file src/views/layout.ejs
     @description 全站布局模板。调用说明：renderPage 二次渲染时套用，注入导航、字体、客户端 i18n。
-->
<!DOCTYPE html>
<html lang="<%= locale || 'zh-CN' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <title><%= title %> - <%= appName %></title>
  <%
    const esc = typeof escapeHtml === 'function'
      ? escapeHtml
      : (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    const pageMeta = locals.meta || {};
    const metaTitle = `${title} - ${appName}`;
    const metaDescription = pageMeta.description || t('楼阁默认分享描述');
    const metaImage = pageMeta.image || '/public/icons/og-louge.png';
    const metaUrl = pageMeta.url || appUrl;
    const metaType = pageMeta.type || 'website';
    const metaSiteName = pageMeta.siteName || appName;
    const twitterCard = pageMeta.twitterCard || 'summary_large_image';
  %>
  <meta name="description" content="<%- esc(metaDescription) %>" />
  <meta property="og:site_name" content="<%- esc(metaSiteName) %>" />
  <meta property="og:type" content="<%- esc(metaType) %>" />
  <meta property="og:title" content="<%- esc(metaTitle) %>" />
  <meta property="og:description" content="<%- esc(metaDescription) %>" />
  <meta property="og:url" content="<%- esc(metaUrl) %>" />
  <meta property="og:image" content="<%- esc(metaImage) %>" />
  <meta property="og:image:secure_url" content="<%- esc(metaImage) %>" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="<%- esc(twitterCard) %>" />
  <meta name="twitter:title" content="<%- esc(metaTitle) %>" />
  <meta name="twitter:description" content="<%- esc(metaDescription) %>" />
  <meta name="twitter:image" content="<%- esc(metaImage) %>" />
  <meta itemprop="name" content="<%- esc(metaTitle) %>" />
  <meta itemprop="description" content="<%- esc(metaDescription) %>" />
  <meta itemprop="image" content="<%- esc(metaImage) %>" />
  <link rel="icon" href="/public/icons/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/public/icons/icon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/public/icons/icon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/public/icons/icon-180.png" />
  <link rel="manifest" href="/public/icons/site.webmanifest" />
  <meta name="theme-color" content="#0b3f45" />
  <link rel="preconnect" href="https://fonts.xuejourney.xin" crossorigin />
  <link rel="preload" href="<%= assetUrl('/public/styles/site-pages.css') %>" as="style" />
  <link rel="stylesheet" href="https://fonts.xuejourney.xin/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" />
  <% ((typeof fontStylesheetUrls !== 'undefined' && fontStylesheetUrls) || []).forEach((fontStylesheetUrl) => { %>
    <% if (fontStylesheetUrl && fontStylesheetUrl !== 'https://fonts.xuejourney.xin/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap') { %>
      <link rel="stylesheet" href="<%= fontStylesheetUrl %>" />
    <% } %>
  <% }) %>
  <link rel="stylesheet" href="<%= assetUrl('/public/styles/site-pages.css') %>" />
  <% if (liveReloadEnabled) { %>
    <script nonce="<%= cspNonce || '' %>">
      window.LOUGE_LIVE_RELOAD = {
        enabled: true,
        endpoint: '/__live-reload/events',
        cssVersion: '<%- esc(assetVersion('/public/styles/site-pages.css')) %>',
        reloadVersion: '<%- esc(liveReloadAssetVersion || '') %>'
      };
    </script>
  <% } %>
  <script id="app-bootstrap-data" type="application/json" nonce="<%= cspNonce || '' %>"><%- JSON.stringify({
    i18n: { locale: locale || 'zh-CN', messages: clientI18nMessages || {} },
    notifications: { items: clientNotifications || [] },
    siteMessages: { unreadCount: unreadSiteMessageCount || 0 },
    currentUser: currentUser ? { id: currentUser.id, username: currentUser.username, role: currentUser.role } : null,
    csrfToken: csrfToken || ''
  }) %></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/layout-bootstrap.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/i18n-runtime.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/csrf.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/form-guards.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/tag-input.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/generated/notification.bundle.js') %>" defer></script>
  <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/site-message-client.js') %>" defer></script>
  <% if (liveReloadEnabled) { %>
    <script nonce="<%= cspNonce || '' %>" src="<%= assetUrl('/public/js/live-reload-client.js') %>" defer></script>
  <% } %>
</head>
<body>
  <div class="container">
    <div class="nav">
      <a class="brand" href="/"><%= appName %></a>
      <span class="brand-url"><%= appUrl %></span>
      <% ((typeof navigation !== 'undefined' && navigation.layoutNavItems) || []).forEach(item => { %>
        <a href="<%= item.href %>" class="<%= item.badge === 'siteMessages' ? 'site-message-nav-link' : '' %>"><%= item.label %><% if (item.badge === 'siteMessages') { %><span class="site-message-badge" data-site-message-badge <%= (unreadSiteMessageCount || 0) > 0 ? '' : 'hidden' %>><%= (unreadSiteMessageCount || 0) > 99 ? '99+' : (unreadSiteMessageCount || 0) %></span><% } %></a>
      <% }) %>
      <button type="button" class="nav-support-button" data-open-support><%= t('联系客服') %></button>
      <% if (currentUser) { %>
        <form method="POST" action="/logout" class="inline-form nav-logout-form"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" /><button type="submit" class="nav-link-button"><%= t('退出（{username}）', { username: currentUser.username }) %></button></form>
      <% } %>
      <span class="nav-locale-switch">
        <span><%= t('语言') %>:</span>
        <a href="<%= localeSwitchLinks['zh-TW'] %>" class="<%= locale === 'zh-TW' ? 'active' : '' %>"><%= t('繁體') %></a>
        <a href="<%= localeSwitchLinks['zh-CN'] %>" class="<%= locale === 'zh-CN' ? 'active' : '' %>"><%= t('中文') %></a>
        <a href="<%= localeSwitchLinks.en %>" class="<%= locale === 'en' ? 'active' : '' %>"><%= t('English') %></a>
      </span>
    </div>
    <%- body %>
  </div>
</body>
</html>
