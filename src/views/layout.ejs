<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> - <%= appName %></title>
  <link rel="stylesheet" href="/public/styles/site-pages.css" />
</head>
<body>
  <div class="container">
    <div class="nav">
      <a class="brand" href="/"><%= appName %></a>
      <span class="brand-url"><%= appUrl %></span>
      <a href="/">首页</a>
      <% if (currentUser) { %>
        <a href="/dashboard">控制台</a>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/admin">管理后台</a>
      <% } %>
        <a href="/characters/new">创建角色</a>
        <a href="/logout">退出（<%= currentUser.username %>）</a>
      <% } else { %>
        <a href="/login">登录</a>
        <a href="/register">注册</a>
      <% } %>
    </div>
    <%- body %>
  </div>
</body>
</html>
