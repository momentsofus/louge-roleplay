<!-- @file src/views/admin.ejs
     @description 管理员总览页面模板。调用说明：GET /admin 渲染，展示用户/套餐/Provider 概览入口。
-->
<%
  const adminUsers = Array.isArray(users) ? users : [];
  const adminCount = Number(overview?.adminUsers || 0);
  const activeUsers = Number(overview?.activeUsers || 0);
  const planBoundCount = Number(overview?.planBoundUsers || 0);
  const inactiveUsers = Number(overview?.inactiveUsers || 0);
  const vm = (typeof viewModel !== 'undefined' ? viewModel : locals.viewModel) || {};
  const roleLabel = (role) => vm.roleLabel ? vm.roleLabel(role, t) : (role === 'admin' ? t('管理员') : t('普通用户'));
  const statusLabel = (status) => vm.statusLabel ? vm.statusLabel(status, t) : (status === 'active' ? t('正常') : t(status || '未知'));
  const safeNum = vm.safeNumber || ((value) => {
    const num = Number(value || 0);
    return Number.isFinite(num) ? num : 0;
  });
  const formatNum = (value) => vm.formatNumber ? vm.formatNumber(value, locale || 'zh-CN') : safeNum(value).toLocaleString('zh-CN');
  const quotaPeriodLabel = (period) => vm.quotaPeriodLabel ? vm.quotaPeriodLabel(period, t) : ({ daily: t('每日'), monthly: t('每月'), lifetime: t('永久') }[period] || period || t('未知'));
  const billingModeLabel = (mode) => vm.billingModeLabel ? vm.billingModeLabel(mode, t) : ({ per_request: t('按请求'), per_token: t('按 Token'), hybrid: t('混合计费') }[mode] || mode || t('未知'));
  const quotaTone = (state) => state === 'danger' ? 'danger' : (state === 'warn' ? 'warn' : 'healthy');
%>
<div class="admin-shell">
  <section class="hero-card admin-hero">
    <div class="admin-hero-copy">
      <p class="section-kicker">Admin Console</p>
      <h1>管理员后台</h1>
      <p class="muted-text">配置类内容我已经从总后台里拆开了。这里保留总览和用户权限，LLM、套餐、Prompt 都去各自单独页面，终于不挤成一锅了。</p>
    </div>

    <div class="metrics">
      <div class="metric"><strong><%= overview.totalUsers %></strong><span>用户总数</span></div>
      <div class="metric"><strong><%= overview.activeSubscriptions %></strong><span>有效套餐</span></div>
      <div class="metric"><strong><%= overview.activeProviders %> / <%= overview.totalProviders %></strong><span>Provider 状态</span></div>
      <div class="metric">
        <strong><%= overview.queuedJobs %></strong>
        <span>实时队列</span>
        <small class="metric-subtle"><%= '运行' %> <%= overview.runtimeQueueActive || 0 %> / <%= '等待' %> <%= overview.runtimeQueuePending || 0 %></small>
        <% if (overview.staleRunningJobs) { %>
          <small class="metric-warning"><%= overview.staleRunningJobs %> 个历史挂起任务未计入</small>
        <% } %>
      </div>
    </div>
  </section>

  <section class="section-card admin-section">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Workspace</p>
        <h2>配置分区</h2>
        <p class="muted-text">三个重配置模块都单独拆页了。你想改哪块，就直接进对应页面，不用在一页里来回找。</p>
      </div>
    </div>

    <%- include('partials/admin-subnav', { activeAdminNav: 'dashboard' }) %>

    <div class="admin-hub-grid admin-hub-grid--tools">
      <% ((typeof navigation !== 'undefined' && navigation.adminHubItems) || []).forEach(item => { %>
        <a class="admin-hub-card" href="<%= item.href %>">
          <span class="pill pill--brand"><%= item.badge %></span>
          <strong><%= item.label %></strong>
          <p><%= item.description %></p>
        </a>
      <% }) %>
    </div>
  </section>

  <section class="section-card admin-section admin-users-section">
    <div class="section-heading admin-users-heading">
      <div>
        <p class="section-kicker">Users & Access</p>
        <h2>用户与权限</h2>
        <p class="muted-text"><%= t('用户当前套餐、请求余量、Token 余量和关键限制都收进卡片里；后台不用再来回翻日志确认余额。') %></p>
      </div>
      <div class="section-actions section-actions--stack">
        <label class="search-field search-field--large">
          <span>筛选用户</span>
          <input type="search" placeholder="用户名 / 昵称 / 邮箱 / 手机 / 套餐" data-admin-filter data-filter-target="users-list" />
        </label>
      </div>
    </div>

    <div class="admin-users-summary" aria-label="用户权限概览">
      <div class="admin-users-summary-card">
        <span>管理员</span>
        <strong><%= adminCount %></strong>
        <small>拥有后台访问权限</small>
      </div>
      <div class="admin-users-summary-card">
        <span>正常用户</span>
        <strong><%= activeUsers %></strong>
        <small>状态为 active</small>
      </div>
      <div class="admin-users-summary-card">
        <span>已绑定套餐</span>
        <strong><%= planBoundCount %></strong>
        <small>当前有有效套餐关系</small>
      </div>
      <div class="admin-users-summary-card">
        <span>非正常状态</span>
        <strong><%= inactiveUsers %></strong>
        <small>需要人工关注</small>
      </div>
    </div>

    <div class="permission-layout">
      <aside class="permission-guide-card">
        <p class="section-kicker">Guardrails</p>
        <h3>权限调整前确认</h3>
        <ul>
          <li>授予管理员会开放后台入口，请确认账号归属。</li>
          <li><%= t('切换套餐会立即影响模型可见范围、倍率和额度；卡片内余量按当前套餐周期实时计算。') %></li>
          <li>联系方式为空时，优先用用户名或公开 ID 识别用户。</li>
          <li><%= t('禁用会阻止账号继续登录；删除会级联移除该用户角色、会话、订阅和用量日志。') %></li>
        </ul>
      </aside>

      <div class="user-card-list" id="users-list">
        <% if (!adminUsers.length) { %>
          <div class="empty-state">
            <strong>还没有用户</strong>
            <span>等第一个用户注册后，这里会出现权限卡片。</span>
          </div>
        <% } %>

        <% adminUsers.forEach(u => { %>
          <%
            const usernameForFilter = [u.public_id || '', u.username, u.nickname || '', u.email || '', u.phone || '', u.plan_name || '', u.plan_code || '', u.role || '', u.status || '', u.country_type || ''].join(' ');
            const isAdmin = u.role === 'admin';
            const isActive = u.status === 'active';
          %>
          <article class="user-permission-card" data-filter-item data-filter-text="<%= usernameForFilter %>">
            <header class="user-card-header">
              <div class="user-avatar" aria-hidden="true"><%= String(u.nickname || u.username || '?').trim().slice(0, 1).toUpperCase() %></div>
              <div class="user-card-title">
                <div class="toolbar-row toolbar-row--tight">
                  <h3><%= u.nickname || u.username %></h3>
                  <span class="pill <%= isAdmin ? 'pill--brand' : '' %>"><%= roleLabel(u.role) %></span>
                  <span class="pill <%= isActive ? 'pill--success' : 'pill--level-warn' %>"><%= statusLabel(u.status) %></span>
                </div>
                <p class="muted-text">
                  @<%= u.username %>
                  <% if (u.public_id) { %> · ID：<%= u.public_id %><% } %>
                  · <%= u.country_type || 'domestic' %>
                </p>
              </div>
            </header>

            <div class="user-card-grid">
              <section class="user-info-panel">
                <span class="user-info-label">联系信息</span>
                <strong><%= u.email || '未绑定邮箱' %></strong>
                <small>手机：<%= u.phone || '未绑定' %></small>
              </section>
              <section class="user-info-panel">
                <span class="user-info-label"><%= t('注册时间') %></span>
                <strong><%= u.created_at || '—' %></strong>
                <small><%= t('用户 ID') %>：<%= u.id %></small>
              </section>
              <section class="user-info-panel user-plan-panel">
                <span class="user-info-label">当前套餐</span>
                <% if (u.plan_name) { %>
                  <strong><%= u.plan_name %> <span class="muted-text">(<%= u.plan_code %>)</span></strong>
                  <small><%= billingModeLabel(u.billing_mode) %><%= t('· 刷新 ·') %><%= quotaPeriodLabel(u.quota_period) %> · <%= '优先级' %> <%= u.priority_weight %> · <%= '并发' %> <%= u.concurrency_limit %></small>
                  <% if (u.plan_description) { %><small class="user-plan-description"><%= u.plan_description %></small><% } %>
                <% } else { %>
                  <strong>未绑定套餐</strong>
                  <small>该用户可能无法正常使用付费模型。</small>
                <% } %>
              </section>
            </div>

            <% if (u.quota_snapshot) { %>
              <% const tone = quotaTone(u.quota_state); %>
              <section class="user-quota-panel user-quota-panel--<%= tone %>" aria-label="<%= t('用户套餐余量') %>">
                <div class="user-quota-heading">
                  <div>
                    <span class="user-info-label"><%= t('套餐余量') %></span>
                    <strong><%= quotaPeriodLabel(u.quota_period) %>额度快照</strong>
                  </div>
                  <span class="quota-health-pill quota-health-pill--<%= tone %>"><%= tone === 'danger' ? t('接近耗尽') : (tone === 'warn' ? t('使用较高') : t('余量正常')) %></span>
                </div>
                <div class="user-quota-grid">
                  <div class="user-quota-meter">
                    <div class="quota-row-head">
                      <span><%= t('请求余量') %></span>
                      <strong><%= formatNum(u.remaining_requests) %> / <%= formatNum(u.request_quota) %></strong>
                    </div>
                    <div class="quota-bar quota-bar--admin"><span data-width="<%= u.request_usage_percent %>"></span></div>
                    <div class="dashboard-item-meta user-quota-meta">
                      <span><%= t('已用') %> <%= formatNum(u.used_requests) %></span>
                      <span><%= u.request_usage_percent %>%</span>
                    </div>
                  </div>
                  <div class="user-quota-meter">
                    <div class="quota-row-head">
                      <span><%= t('Token 余量') %></span>
                      <strong><%= formatNum(u.remaining_tokens) %> / <%= formatNum(u.token_quota) %></strong>
                    </div>
                    <div class="quota-bar quota-bar--admin"><span data-width="<%= u.token_usage_percent %>"></span></div>
                    <div class="dashboard-item-meta user-quota-meta">
                      <span><%= t('已用') %> <%= formatNum(u.used_tokens) %></span>
                      <span><%= u.token_usage_percent %>%</span>
                    </div>
                  </div>
                </div>
                <dl class="user-plan-detail-list">
                  <div><dt><%= t('计费') %></dt><dd><%= billingModeLabel(u.billing_mode) %></dd></div>
                  <div><dt><%= t('周期') %></dt><dd><%= quotaPeriodLabel(u.quota_period) %></dd></div>
                  <div><dt><%= t('最大输出') %></dt><dd><%= formatNum(u.max_output_tokens) %></dd></div>
                  <div><dt><%= t('可用模型') %></dt><dd><%= formatNum(u.model_count) %></dd></div>
                  <div><dt><%= t('订阅开始') %></dt><dd><%= u.subscription_started_at || '—' %></dd></div>
                </dl>
              </section>
            <% } else { %>
              <section class="user-quota-panel user-quota-panel--empty" aria-label="<%= t('用户套餐余量') %>">
                <div class="user-quota-heading">
                  <div>
                    <span class="user-info-label"><%= t('套餐余量') %></span>
                    <strong><%= t('暂无有效套餐') %></strong>
                  </div>
                  <span class="quota-health-pill quota-health-pill--danger"><%= t('不可用') %></span>
                </div>
                <p class="muted-text"><%= t('为该用户切换到有效套餐后，这里会显示请求和 Token 的实时剩余额度。') %></p>
              </section>
            <% } %>

            <div class="user-card-actions">
              <form class="compact-admin-form" method="post" action="/admin/users/<%= u.id %>/role">
                <label>
                  <span>用户角色</span>
                  <select name="role">
                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>普通用户</option>
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>管理员</option>
                  </select>
                </label>
                <button type="submit">保存角色</button>
              </form>

              <form class="compact-admin-form" method="post" action="/admin/users/<%= u.id %>/plan">
                <label>
                  <span>用户套餐</span>
                  <select name="planId">
                    <% plans.forEach(plan => { %>
                      <option value="<%= plan.id %>" <%= plan.code === u.plan_code ? 'selected' : '' %>>
                        <%= plan.name %> (<%= plan.code %>)
                      </option>
                    <% }) %>
                  </select>
                </label>
                <button type="submit">切换套餐</button>
              </form>

              <form class="compact-admin-form" method="post" action="/admin/users/<%= u.id %>/status">
                <label>
                  <span><%= t('账号状态') %></span>
                  <select name="status">
                    <option value="active" <%= u.status === 'active' ? 'selected' : '' %>><%= t('正常') %></option>
                    <option value="blocked" <%= u.status === 'blocked' ? 'selected' : '' %>><%= t('禁用') %></option>
                  </select>
                </label>
                <button type="submit"><%= t(isActive ? '禁用/保存状态' : '启用/保存状态') %></button>
              </form>

              <form class="compact-admin-form compact-admin-form--danger" method="post" action="/admin/users/<%= u.id %>/delete" data-confirm-message="<%= t('确定删除这个用户？该用户的角色、会话、订阅和用量日志会一并删除，且不可恢复。') %>">
                <span class="danger-copy"><%= t('危险操作') %></span>
                <button class="danger-button" type="submit"><%= t('删除用户') %></button>
              </form>
            </div>
          </article>
        <% }) %>
        <div class="empty-state admin-filter-empty">
          <strong>没有匹配的用户</strong>
          <span>换个用户名、邮箱、手机或套餐关键词试试。</span>
        </div>
      </div>
    </div>
  </section>
</div>

<script nonce="<%= cspNonce || '' %>" src="/public/js/admin-page.js"></script>
