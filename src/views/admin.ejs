<!-- @file src/views/admin.ejs
     @description 管理员总览页面模板。调用说明：GET /admin 渲染，展示用户/套餐/Provider 概览入口。
-->
<div class="admin-shell">
  <section class="hero-card admin-hero">
    <div class="admin-hero-copy">
      <p class="section-kicker">Admin Console</p>
      <h1>管理员后台</h1>
      <p class="muted-text">配置类内容我已经从总后台里拆开了。这里保留总览和用户权限，LLM、套餐、Prompt 都去各自单独页面，终于不挤成一锅了。</p>
    </div>

    <div class="metrics">
      <div class="metric"><strong><%= overview.totalUsers %></strong><span>用户总数</span></div>
      <div class="metric"><strong><%= overview.activeSubscriptions %></strong><span>有效套餐</span></div>
      <div class="metric"><strong><%= overview.activeProviders %> / <%= overview.totalProviders %></strong><span>Provider 状态</span></div>
      <div class="metric"><strong><%= overview.queuedJobs %></strong><span>队列中作业</span></div>
    </div>
  </section>

  <section class="section-card admin-section">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Workspace</p>
        <h2>配置分区</h2>
        <p class="muted-text">三个重配置模块都单独拆页了。你想改哪块，就直接进对应页面，不用在一页里来回找。</p>
      </div>
    </div>

    <div class="admin-hub-grid admin-hub-grid--tools">
      <a class="admin-hub-card" href="/admin/providers">
        <span class="pill pill--brand">LLM</span>
        <strong>LLM 配置</strong>
        <p>Provider、模型绑定、并发、超时、价格都放这边。</p>
      </a>
      <a class="admin-hub-card" href="/admin/plans">
        <span class="pill pill--brand">Plans</span>
        <strong>套餐配置</strong>
        <p>套餐额度、计费模式、默认套餐、优先级这些都单独管。</p>
      </a>
      <a class="admin-hub-card" href="/admin/prompts">
        <span class="pill pill--brand">Prompt</span>
        <strong>Prompt 配置</strong>
        <p>全局片段、排序和最终 Prompt 预览都在这里，不再跟别的表单挤一起。</p>
      </a>
      <a class="admin-hub-card" href="/admin/notifications">
        <span class="pill pill--brand">Notice</span>
        <strong>通知中心</strong>
        <p>客服入口、站内通知、强制弹窗和新人提醒统一配置。</p>
      </a>
      <a class="admin-hub-card" href="/admin/logs">
        <span class="pill pill--brand">Logs</span>
        <strong>日志查询</strong>
        <p>按日期、等级、文件、错误类型和函数名筛查运行日志。</p>
      </a>
      <a class="admin-hub-card" href="/admin/conversations">
        <span class="pill pill--brand">Chats</span>
        <strong>对话记录</strong>
        <p>全局查看会话，按用户、角色卡和日期筛选。</p>
      </a>
    </div>
  </section>

  <section class="section-card admin-section">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Users</p>
        <h2>用户与权限</h2>
        <p class="muted-text">总后台只保留用户管理。角色和套餐切换还在，找人我也给你留了搜索。</p>
      </div>
      <div class="section-actions section-actions--stack">
        <label class="search-field">
          <span>筛选用户</span>
          <input type="search" placeholder="用户名 / 昵称 / 邮箱 / 手机 / 套餐" data-admin-filter data-filter-target="users-list" />
        </label>
      </div>
    </div>

    <div class="admin-subnav">
      <a class="quick-link is-active" href="/admin">用户与总览</a>
      <a class="quick-link" href="/admin/providers">LLM 配置</a>
      <a class="quick-link" href="/admin/plans">套餐配置</a>
      <a class="quick-link" href="/admin/prompts">Prompt 配置</a>
      <a class="quick-link" href="/admin/notifications">通知中心</a>
      <a class="quick-link" href="/admin/logs">日志查询</a>
      <a class="quick-link" href="/admin/conversations">对话记录</a>
    </div>

    <div class="table-wrap admin-table-shell">
      <table class="admin-table">
        <thead>
          <tr>
            <th>用户</th>
            <th>联系</th>
            <th>当前套餐</th>
            <th>角色切换</th>
            <th>套餐切换</th>
          </tr>
        </thead>
        <tbody id="users-list">
          <% users.forEach(u => { %>
            <%
              const usernameForFilter = [u.public_id || '', u.username, u.nickname || '', u.email || '', u.phone || '', u.plan_name || '', u.plan_code || '', u.role || '', u.status || ''].join(' ');
            %>
            <tr data-filter-item data-filter-text="<%= usernameForFilter %>">
              <td>
                <strong><%= u.username %></strong>
                <div class="muted-text">
                  ID：<%= u.public_id || '—' %>
                  · <%= u.nickname || '—' %>
                  · 状态：<%= u.status %>
                  · 地区：<%= u.country_type || 'domestic' %>
                </div>
              </td>
              <td class="muted-text">
                邮箱：<%= u.email || '—' %><br />
                手机：<%= u.phone || '—' %>
              </td>
              <td>
                <% if (u.plan_name) { %>
                  <strong><%= u.plan_name %></strong>
                  <div class="muted-text">
                    <%= u.billing_mode %>
                    · 优先级 <%= u.priority_weight %>
                    · 并发 <%= u.concurrency_limit %>
                  </div>
                <% } else { %>
                  <span class="muted-text">未绑定</span>
                <% } %>
              </td>
              <td>
                <form method="post" action="/admin/users/<%= u.id %>/role">
                  <select name="role">
                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>普通用户</option>
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>管理员</option>
                  </select>
                  <button type="submit">保存角色</button>
                </form>
              </td>
              <td>
                <form method="post" action="/admin/users/<%= u.id %>/plan">
                  <select name="planId">
                    <% plans.forEach(plan => { %>
                      <option value="<%= plan.id %>" <%= plan.code === u.plan_code ? 'selected' : '' %>>
                        <%= plan.name %> (<%= plan.code %>)
                      </option>
                    <% }) %>
                  </select>
                  <button type="submit">切换套餐</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<script nonce="<%= cspNonce || '' %>" src="/public/js/admin-page.js"></script>
