{
  "name": "ai-roleplay-site",
  "version": "1.5.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "薛中泽",
  "description": "楼阁：多用户 AI 角色对话网站，含角色、聊天、后台、套餐、Provider 管理与 Tavern 卡导入",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/XueJourney/louge-roleplay.git"
  },
  "keywords": [
    "louge",
    "ai-roleplay",
    "express",
    "ejs",
    "private-software"
  ],
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "node scripts/build-css.js",
    "db:init": "node scripts/init-db.js",
    "grant-admin": "node scripts/grant-admin.js",
    "smoke:test": "node scripts/smoke-test.js",
    "health:check": "node scripts/health-check.js",
    "security:audit": "node scripts/security-audit.js",
    "test:think": "node scripts/test-think-parser.js",
    "test:prompt-route": "node scripts/test-prompt-route.js",
    "test:character-tags": "node scripts/test-character-tags.js",
    "docs:debug": "node scripts/update-docs-debug.js",
    "logs:test": "node scripts/test-log-service.js",
    "error-handler:test": "node scripts/test-error-handler.js",
    "admin-logs:test": "node scripts/test-admin-logs-route.js",
    "admin-conversations:test": "node scripts/test-admin-conversations.js",
    "conversation-service:test": "node scripts/test-conversation-service.js",
    "full-flow:test": "node scripts/full-flow-e2e.js",
    "version:check": "node scripts/version-check.js",
    "version:bump:patch": "npm version patch --no-git-tag-version",
    "version:bump:minor": "npm version minor --no-git-tag-version",
    "version:bump:major": "npm version major --no-git-tag-version",
    "i18n:check": "node scripts/check-i18n-completeness.js",
    "model-entitlements:test": "node scripts/test-model-entitlements.js",
    "tavern-import:test": "node scripts/test-tavern-import-tags-nsfw.js",
    "character-delete:test": "node scripts/test-character-delete-service.js",
    "prompt-template:test": "node scripts/test-prompt-template.js",
    "backfill:character-stats": "node scripts/backfill-character-stats.js",
    "build:js": "node scripts/build-js.js",
    "build": "npm run build:css && npm run build:js",
    "conversation-management:test": "node scripts/test-user-conversation-management.js"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "^2.0.0",
    "@alicloud/dysmsapi20170525": "^4.5.1",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.2",
    "opencc-js": "^1.3.0",
    "redis": "^5.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
